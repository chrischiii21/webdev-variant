---
import BaseLayout from "../layouts/BaseLayout.astro";

const pages = [
    { title: "Home", url: "/" },
    { title: "About Us", url: "/about" },
    { title: "What We Do", url: "/what-we-do" },
    { title: "Trades We Serve", url: "/trades-we-serve" },
    { title: "Our Work", url: "/our-work" },
    { title: "Reviews", url: "/reviews" },
    { title: "Contact", url: "/contact" },
    { title: "Privacy Policy", url: "/privacy" },
    { title: "Terms of Service", url: "/terms" },
];
---

<BaseLayout
    title="Sitemap - Webdev Variant"
    description="Navigate through all pages on our website"
>
    <main class="min-h-screen py-16 px-4">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-4xl font-bold mb-8">Sitemap</h1>
            <ul class="space-y-4">
                {
                    pages.map((page) => (
                        <li>
                            <a
                                href={page.url}
                                class="text-lg text-blue-600 hover:text-blue-800 hover:underline"
                            >
                                {page.title}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>
    </main>
</BaseLayout>
