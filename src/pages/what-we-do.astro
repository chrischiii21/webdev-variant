---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
import CoreOffering from "../components/layout/CoreOffering.astro";
import WhyChooseUs from "../components/layout/WhyChooseUs.astro";
import FAQ from "../components/layout/FAQ.astro";
import CTA from "../components/layout/CTA.astro";
---

<BaseLayout
    title="What We Do - Webdev Variant"
    description="Discover our comprehensive range of engineering and construction services"
>
    <Hero2
        title="What We Do"
        breadcrumbItems={[
            { label: "HOME", href: "/" },
            { label: "WHAT WE DO" },
        ]}
    />
    <CoreOffering />
    <WhyChooseUs />
    <FAQ />
    <CTA />
</BaseLayout>
