---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
import CoreOffering from "../components/layout/CoreOffering.astro";
import WhyChooseUs from "../components/layout/WhyChooseUs.astro";
---

<BaseLayout
    title="What We Do - Webdev Variant"
    description="Discover our comprehensive range of engineering and construction services"
>
    <Hero2
        title="What We Do"
        subtitle="Our Services"
        description="We create high-performance websites, marketing systems, and digital tools that help contractors generate more leads, close more deals, and grow their businesses."
        showCTA={true}
        ctaText="Learn More"
        ctaHref="/contact"
    />
    <CoreOffering />
    <WhyChooseUs />
</BaseLayout>
