---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero2 from "../../components/layout/Hero2.astro";
import TemplateCard from "../../components/ui/TemplateCard.astro";
import Button from "../../components/ui/Button.astro";
import FAQ from "../../components/layout/FAQ.astro";
import CTA from "../../components/layout/CTA.astro";

export async function getStaticPaths() {
    const trades = await getCollection("trades");
    const allTemplates = await getCollection("templates");

    return trades.map((trade) => {
        // Filter templates for this specific trade
        const tradeTemplates = allTemplates
            .filter((template) => template.data.trade === trade.data.slug)
            .sort((a, b) => (a.data.order || 1) - (b.data.order || 1));

        return {
            params: { slug: trade.data.slug },
            props: { trade, templates: tradeTemplates },
        };
    });
}

const { trade, templates } = Astro.props;
const { name, tagline, hoverDescription, image } = trade.data;
---

<BaseLayout
    title={`${name} - Webdev Variant`}
    description={hoverDescription || tagline}
>
    <!-- Hero Section -->
    <Hero2 
        title={name}
        subtitle={tagline}
        description={hoverDescription || tagline}
        image={image}
        showCTA={true}
        ctaText="Get a Quote"
        ctaHref="/contact"
    />
        <!-- Templates Section -->
        <section class="templates-section relative py-20 overflow-hidden">
            <!-- Background -->
            <div class="absolute inset-0 bg-gradient-to-b from-black/5 via-transparent to-black/5"></div>
            
            <!-- Decorative gradients -->
            <div class="absolute top-20 right-0 w-96 h-96 opacity-10 pointer-events-none" style="background: radial-gradient(circle, #2F8EF8 0%, transparent 70%);"></div>
            <div class="absolute bottom-20 left-0 w-96 h-96 opacity-8 pointer-events-none" style="background: radial-gradient(circle, #94F9FD 0%, transparent 70%);"></div>

            <div class="max-w-7xl mx-auto px-8 relative z-10">
                <!-- Section Header -->
                <div class="text-center mb-16">
                    <h2 class="text-4xl md:text-5xl font-bold text-white mb-6" style="font-family: 'Poppins', sans-serif;">
                        <span class="text-white">{name}</span>
                        <span class="text-[#2F8EF8]"> Templates</span>
                    </h2>
                    <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed" style="font-family: 'Poppins', sans-serif;">
                        {templates && templates.length > 0 
                            ? `Choose from our professionally designed templates tailored for ${name.toLowerCase()}`
                            : `We're currently working on amazing ${name.toLowerCase()} templates`
                        }
                    </p>
                </div>

                {templates && templates.length > 0 ? (
                    <!-- Templates Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {templates.map((template) => (
                            <TemplateCard
                                title={template.data.title}
                                category={template.data.category}
                                description={template.data.description}
                                image={template.data.image}
                                stats={template.data.stats}
                                href={template.data.liveDemoUrl || template.data.mainSiteUrl || '#'}
                                linkText="View Live Demo"
                            />
                        ))}
                    </div>
                ) : (
                    <!-- Placeholder for trades without templates -->
                    <div class="bg-[#1B222C] border-2 border-[#2F8EF8]/30 rounded-3xl p-12 text-center">
                        <div class="max-w-md mx-auto">
                            <svg class="w-16 h-16 text-[#94F9FD] mx-auto mb-6 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                            </svg>
                            <h3 class="text-xl font-bold text-white mb-3" style="font-family: 'Poppins', sans-serif;">
                                {name} Templates Coming Soon
                            </h3>
                            <p class="text-gray-400 mb-6" style="font-family: 'Poppins', sans-serif;">
                                We're currently working on amazing {name.toLowerCase()} templates. Check back soon or contact us to discuss your project!
                            </p>
                            <Button
                                variant="secondary"
                                size="sm"
                                href="/contact"
                                ariaLabel={`Contact us about ${name} services`}
                            >
                                Get Started
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                </svg>
                            </Button>
                        </div>
                    </div>
                )}
            </div>
        </section>
    <FAQ />
    <CTA />
</BaseLayout>
