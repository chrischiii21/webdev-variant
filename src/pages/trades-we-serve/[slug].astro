---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/layout/Navbar.astro";
import Footer from "../../components/layout/Footer.astro";

export async function getStaticPaths() {
    const trades = await getCollection("trades");
    return trades.map((trade) => ({
        params: { slug: trade.data.slug },
        props: { trade },
    }));
}

const { trade } = Astro.props;
const { name, tagline, hoverDescription, image } = trade.data;
---

<BaseLayout
    title={`${name} - Webdev Variant`}
    description={hoverDescription || tagline}
>
    <Navbar />

    <main style="padding-top: 100px; min-height: 100vh;">
        <section style="max-width: 1200px; margin: 0 auto; padding: 60px 32px;">
            <div
                style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;"
            >
                <!-- Content -->
                <div>
                    <h1
                        style="font-family: var(--font-primary); font-size: 3rem; font-weight: 700; color: var(--text-charcoal); margin-bottom: 16px;"
                    >
                        {name}
                    </h1>
                    <p
                        style="font-family: var(--font-primary); font-size: 1.25rem; color: var(--secondary-gray-blue); margin-bottom: 24px;"
                    >
                        {tagline}
                    </p>
                    <p
                        style="font-family: var(--font-primary); font-size: 1.125rem; color: var(--text-charcoal); line-height: 1.8; margin-bottom: 32px;"
                    >
                        {hoverDescription || tagline}
                    </p>
                    <a
                        href="/contact"
                        style="display: inline-flex; align-items: center; gap: 8px; padding: 16px 32px; background: var(--primary-blue); color: white; font-family: var(--font-primary); font-weight: 600; border-radius: 8px; text-decoration: none; transition: all 0.3s ease;"
                        onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(37, 99, 235, 0.4)';"
                        onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';"
                    >
                        Get a Quote
                        <svg
                            style="width: 20px; height: 20px;"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>
                </div>

                <!-- Image -->
                <div>
                    <img
                        src={image}
                        alt={name}
                        style="width: 100%; height: auto; border-radius: 16px; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);"
                    />
                </div>
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    @media (max-width: 768px) {
        section > div {
            grid-template-columns: 1fr !important;
            gap: 40px !important;
        }
    }
</style>
