---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
---

<BaseLayout
    title="Privacy Policy - Webdev Variant"
    description="Read our privacy policy and data protection practices"
>
    <Hero2
        title="Privacy Policy"
        breadcrumbItems={[
            { label: "HOME", href: "/" },
            { label: "PRIVACY POLICY" },
        ]}
    />

    <section class="min-h-screen py-16 px-4">
        <div class="max-w-4xl mx-auto">
            <p class="text-lg text-gray-300">Content coming soon...</p>
        </div>
    </section>
</BaseLayout>
