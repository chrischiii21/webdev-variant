---
import Button from "../ui/Button.astro";

interface Props {
    title?: string;
    description?: string;
    primaryButtonText?: string;
    primaryButtonHref?: string;
    secondaryButtonText?: string;
    secondaryButtonHref?: string;
    showSecondaryButton?: boolean;
    badge?: string;
}

const {
    title = "Ready to Transform Your Business?",
    description = "Join hundreds of contractors who have already boosted their online presence and revenue.",
    primaryButtonText = "Get Started",
    primaryButtonHref = "/contact",
    secondaryButtonText = "View Our Work",
    secondaryButtonHref = "/our-work",
    showSecondaryButton = true,
    badge = "LIMITED SPOTS AVAILABLE",
} = Astro.props;
---

<section
    class="cta-banner relative py-20 overflow-hidden bg-gradient-to-br from-[#0B0829] via-[#0B0829] to-[#1a1540]"
>
    <!-- Primary Gradient Overlay -->
    <div
        class="absolute inset-0 bg-gradient-to-br from-[#0B0829] via-[#1a1540] to-[#0B0829]"
    >
    </div>

    <!-- Orange Accent Gradients -->
    <div class="absolute top-0 left-0 w-full h-full opacity-30">
        <div
            class="absolute top-0 left-1/4 w-[600px] h-[600px] -translate-y-1/2 blur-[120px]"
            style="background: radial-gradient(circle, #FF8400 0%, transparent 70%);"
        >
        </div>
        <div
            class="absolute bottom-0 right-1/4 w-[500px] h-[500px] translate-y-1/2 blur-[100px]"
            style="background: radial-gradient(circle, #8FA0D8 0%, transparent 70%);"
        >
        </div>
    </div>

    <!-- Animated Grid Pattern -->
    <div class="absolute inset-0 opacity-10">
        <div
            class="absolute inset-0"
            style="background-image: linear-gradient(#8FA0D8 1px, transparent 1px), linear-gradient(90deg, #8FA0D8 1px, transparent 1px); background-size: 50px 50px;"
        >
        </div>
    </div>

    <!-- Animated Floating Orbs -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div
            class="absolute top-1/4 left-1/3 w-[300px] h-[300px] opacity-20 animate-float"
            style="background: radial-gradient(circle, #FF8400 0%, transparent 60%);"
        >
        </div>
        <div
            class="absolute bottom-1/4 right-1/3 w-[250px] h-[250px] opacity-15 animate-float-delayed"
            style="background: radial-gradient(circle, #8FA0D8 0%, transparent 60%);"
        >
        </div>
    </div>

    <!-- Top Border Accent -->
    <div
        class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-transparent via-[#FF8400] to-transparent"
    >
    </div>

    <!-- Bottom Border Accent -->
    <div
        class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-transparent via-[#8FA0D8] to-transparent"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-8 relative z-10">
        <div
            class="backdrop-blur-xl bg-gradient-to-br from-[#0B0829]/60 via-[#1a1540]/60 to-[#0B0829]/60 border-2 border-[#8FA0D8]/30 rounded-3xl p-8 lg:p-12 shadow-[0_0_80px_rgba(143,160,216,0.3)] hover:shadow-[0_0_100px_rgba(255,132,0,0.4)] hover:border-[#FF8400]/50 transition-all duration-500"
        >
            <div
                class="flex flex-col lg:flex-row items-center justify-between gap-8"
            >
                <!-- Content -->
                <div class="text-center lg:text-left flex-1">
                    <!-- Attention Badge -->
                    <div
                        class="inline-flex items-center gap-2 bg-gradient-to-r from-[#FF8400] to-[#ff9933] px-4 py-2 rounded-full mb-6 shadow-[0_0_20px_rgba(255,132,0,0.5)] animate-bounce-subtle"
                    >
                        <div class="w-2 h-2 bg-white rounded-full animate-ping">
                        </div>
                        <span
                            class="text-xs font-bold uppercase tracking-widest text-white"
                        >
                            {badge}
                        </span>
                    </div>

                    <h2
                        class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 leading-tight"
                    >
                        <span
                            class="inline-block animate-fade-in-up bg-gradient-to-r from-white via-[#F9DFC6] to-white bg-clip-text text-transparent"
                            >{title}</span
                        >
                    </h2>
                    <p
                        class="text-lg md:text-xl text-[#F9DFC6]/90 leading-relaxed max-w-2xl mx-auto lg:mx-0 animate-fade-in-up-delayed"
                    >
                        {description}
                    </p>
                </div>

                <!-- Buttons -->
                <div
                    class="flex flex-col sm:flex-row items-center gap-4 shrink-0 animate-fade-in-up-more-delayed"
                >
                    <Button
                        variant="secondary"
                        theme="dark"
                        size="lg"
                        href={primaryButtonHref}
                        ariaLabel={primaryButtonText}
                    >
                        {primaryButtonText}
                        <svg
                            class="w-5 h-5 animate-arrow-bounce"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </Button>
                    {
                        showSecondaryButton && (
                            <Button
                                variant="outline"
                                theme="dark"
                                size="lg"
                                href={secondaryButtonHref}
                                ariaLabel={secondaryButtonText}
                            >
                                {secondaryButtonText}
                            </Button>
                        )
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .cta-banner {
        font-family: "Roboto", sans-serif;
    }

    /* Floating animation for gradient orbs */
    @keyframes float {
        0%,
        100% {
            transform: translateY(0) translateX(0);
        }
        50% {
            transform: translateY(-20px) translateX(10px);
        }
    }

    @keyframes float-delayed {
        0%,
        100% {
            transform: translateY(0) translateX(0);
        }
        50% {
            transform: translateY(20px) translateX(-10px);
        }
    }

    .animate-float {
        animation: float 8s ease-in-out infinite;
    }

    .animate-float-delayed {
        animation: float-delayed 8s ease-in-out infinite;
        animation-delay: 2s;
    }

    /* Subtle bounce for badge */
    @keyframes bounce-subtle {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-5px);
        }
    }

    .animate-bounce-subtle {
        animation: bounce-subtle 2s ease-in-out infinite;
    }

    /* Arrow bounce animation */
    @keyframes arrow-bounce {
        0%,
        100% {
            transform: translateX(0);
        }
        50% {
            transform: translateX(5px);
        }
    }

    .animate-arrow-bounce {
        animation: arrow-bounce 1.5s ease-in-out infinite;
    }

    /* Fade in up animations */
    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out;
    }

    .animate-fade-in-up-delayed {
        animation: fade-in-up 0.8s ease-out 0.2s both;
    }

    .animate-fade-in-up-more-delayed {
        animation: fade-in-up 0.8s ease-out 0.4s both;
    }
</style>
