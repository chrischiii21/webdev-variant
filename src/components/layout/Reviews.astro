---
const testimonials = [
  {
    name: "John Martinez",
    role: "HVAC Contractor",
    location: "Phoenix, AZ",
    rating: 5,
    text: "The investment I made in my business. Closed 23 new clients in 60 days using their system."
  },
  {
    name: "Sarah Williams",
    role: "Plumbing Services",
    location: "Denver, CO",
    rating: 5,
    text: "One Google ranking went from page 4 to #1. We've had to hire 3 more techs to handle the demand."
  },
  {
    name: "Michael Chen",
    role: "Electrical",
    location: "Seattle, WA",
    rating: 5,
    text: "Best investment I've ever made for my business. Period. No more posting in the Facebook groups begging for leads."
  },
  {
    name: "Emma Rodriguez",
    role: "General Contractor",
    location: "Austin, TX",
    rating: 5,
    text: "Their paid ads strategy brought in $400k in projects in Q4. This team operates on a different level."
  },
  {
    name: "David Thompson",
    role: "Roofing",
    location: "Nashville, TN",
    rating: 5,
    text: "Our competitor has been in business 20 years. We launched 3 years ago and already running them everywhere."
  }
];
---

<section class="relative text-[#0B0829] py-20 px-6 md:px-20 font-sans bg-[#FAF8F5]" style="font-family: 'Roboto', sans-serif;">
  <!-- Subtle Section Background with Glass Effect -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#F5F3F0]/10 to-transparent"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-[#8FA0D8]/5 via-transparent to-[#F5A623]/5"></div>
  
  <!-- Decorative Section Divider - Top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#8FA0D8]/20 to-transparent"></div>
  <div class="absolute top-0 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-transparent via-[#8FA0D8]/30 to-transparent blur-sm"></div>
  
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
    
    <!-- Left Column - Static Image with Stats Badge -->
    <div class="relative group">
      <div class="rounded-[40px] overflow-hidden border-8 border-gray-800/30">
        <img 
          src="https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?auto=format&fit=crop&w=800&q=80" 
          alt="Professional Contractor at Work" 
          class="w-full h-[500px] object-cover"
        />
      </div>
      
      <!-- Stats Badge - Bottom Right -->
      <div class="absolute -bottom-6 -right-6 bg-white p-8 rounded-[30px] border border-[#8FA0D8]/30 shadow-2xl backdrop-blur-sm">
        <h2 class="text-[#8FA0D8] text-5xl font-bold" style="font-family: 'Roboto', sans-serif;">99%</h2>
        <p class="text-gray-600 text-sm mt-1 uppercase tracking-wider" style="font-family: 'Roboto', sans-serif;">Client Satisfaction</p>
      </div>
    </div>

    <!-- Right Column - Testimonial Carousel -->
    <div class="flex flex-col space-y-8">
      
      <!-- Header -->
      <div>
        <div class="flex items-center gap-2 text-[#8FA0D8] mb-4">
          <span class="text-xs font-bold uppercase tracking-[0.2em]" style="font-family: 'Roboto', sans-serif;">Client Testimonial</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold leading-tight text-[#0B0829]" style="font-family: 'Roboto', sans-serif;">
          Client Experiences <br /> That Build Trust.
        </h2>
      </div>

      <!-- Carousel Container -->
      <div class="relative overflow-hidden">
        <div class="carousel-track transition-transform duration-500 ease-out" id="carouselTrack">
          {testimonials.map((testimonial) => (
            <div class="carousel-slide">
              <div class="bg-[#0B0829] backdrop-blur-sm p-10 rounded-[40px] border border-[#8FA0D8]/20 relative overflow-hidden shadow-xl">
                
                <!-- Quote Icon -->
                <div class="absolute top-6 right-10 text-[#8FA0D8] opacity-60">
                  <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 8.44772 14.017 9V12C14.017 12.5523 13.5693 13 13.017 13H11.017C10.4647 13 10.017 12.5523 10.017 12V9C10.017 7.34315 11.3601 6 13.017 6H19.017C20.6739 6 22.017 7.34315 22.017 9V15C22.017 18.3137 19.3307 21 16.017 21H14.017ZM3 21L3 18C3 16.8954 3.89543 16 5 16H8C8.55228 16 9 15.5523 9 15V9C9 8.44772 8.55228 8 8 8H4C3.44772 8 3 8.44772 3 9V12C3 12.5523 2.55228 13 2 13H0V12V9C0 7.34315 1.34315 6 3 6H9C10.6569 6 12 7.34315 12 9V15C12 18.3137 9.31371 21 6 21H3Z" />
                  </svg>
                </div>

                <!-- Testimonial Content -->
                <div class="flex flex-col items-start gap-6">
                  
                  <!-- Customer Info -->
                  <div class="flex items-center gap-4">
                    <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#8FA0D8] to-[#F5A623] flex items-center justify-center text-white font-bold text-xl shrink-0">
                      {testimonial.name.charAt(0)}
                    </div>
                    <div>
                      <h4 class="text-xl font-bold text-[#8FA0D8]" style="font-family: 'Roboto', sans-serif;">{testimonial.name}</h4>
                      <p class="text-gray-300 text-sm" style="font-family: 'Roboto', sans-serif;">{testimonial.role}</p>
                    </div>
                  </div>

                  <!-- Star Rating -->
                  <div class="flex gap-1">
                    {Array.from({ length: testimonial.rating }).map(() => (
                      <span class="text-[#8FA0D8] text-lg">★</span>
                    ))}
                  </div>

                  <!-- Testimonial Text -->
                  <blockquote class="text-lg text-white leading-relaxed" style="font-family: 'Roboto', sans-serif;">
                    "{testimonial.text}"
                  </blockquote>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Carousel Indicators -->
      <div class="flex justify-start gap-2">
        {testimonials.map((_, index) => (
          <button 
            class="carousel-indicator w-3 h-3 rounded-full bg-gray-400 transition-all duration-300 hover:bg-[#8FA0D8]" 
            data-index={index}
            aria-label={`Go to testimonial ${index + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
  
  <!-- Decorative Section Divider - Bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#8FA0D8]/20 to-transparent"></div>
  <div class="absolute bottom-0 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-transparent via-[#8FA0D8]/30 to-transparent blur-sm"></div>
</section>

<script>
  const track = document.getElementById('carouselTrack');
  const indicators = document.querySelectorAll('.carousel-indicator');
  let currentIndex = 0;
  const totalSlides = indicators.length;
  const autoSwipeInterval = 5000; // 5 seconds

  function updateCarousel() {
    if (track) {
      const offset = -currentIndex * 100; // 100% for full width
      track.style.transform = `translateX(${offset}%)`;
      
      // Update indicators
      indicators.forEach((indicator, index) => {
        if (index === currentIndex) {
          indicator.classList.add('bg-[#8FA0D8]');
          indicator.classList.remove('bg-gray-400');
        } else {
          indicator.classList.remove('bg-[#8FA0D8]');
          indicator.classList.add('bg-gray-400');
        }
      });
    }
  }

  function nextSlide() {
    currentIndex = (currentIndex + 1) % totalSlides;
    updateCarousel();
  }

  // Auto-swipe carousel
  let autoSwipeTimer = setInterval(nextSlide, autoSwipeInterval);

  // Reset timer on indicator click
  indicators.forEach((indicator, index) => {
    indicator.addEventListener('click', () => {
      currentIndex = index;
      updateCarousel();
      clearInterval(autoSwipeTimer);
      autoSwipeTimer = setInterval(nextSlide, autoSwipeInterval);
    });
  });

  // Initialize
  updateCarousel();
</script>

<style>
  section {
    font-family: 'Roboto', sans-serif;
  }

  section * {
    font-family: 'Roboto', sans-serif !important;
  }

  .carousel-track {
    display: flex;
    width: 100%;
  }

  .carousel-slide {
    flex-shrink: 0;
    width: 100%;
  }

  .carousel-indicator {
    cursor: pointer;
  }

  .carousel-indicator:hover {
    transform: scale(1.2);
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .carousel-slide {
      width: 100%;
    }
  }
</style>
