---
const testimonials = [
  {
    name: "John Martinez",
    role: "HVAC Contractor",
    location: "Phoenix, AZ",
    rating: 5,
    text: "The investment I made in my business. Closed 23 new clients in 60 days using their system."
  },
  {
    name: "Sarah Williams",
    role: "Plumbing Services",
    location: "Denver, CO",
    rating: 5,
    text: "One Google ranking went from page 4 to #1. We've had to hire 3 more techs to handle the demand."
  },
  {
    name: "Michael Chen",
    role: "Electrical",
    location: "Seattle, WA",
    rating: 5,
    text: "Best investment I've ever made for my business. Period. No more posting in the Facebook groups begging for leads."
  },
  {
    name: "Emma Rodriguez",
    role: "General Contractor",
    location: "Austin, TX",
    rating: 5,
    text: "Their paid ads strategy brought in $400k in projects in Q4. This team operates on a different level."
  },
  {
    name: "David Thompson",
    role: "Roofing",
    location: "Nashville, TN",
    rating: 5,
    text: "Our competitor has been in business 20 years. We launched 3 years ago and already running them everywhere."
  },
  {
    name: "Lisa Park",
    role: "Landscaping",
    location: "Portland, OR",
    rating: 5,
    text: "Tripled our monthly revenue in 4 months. The ROI speaks for itself - this system just works."
  },
  {
    name: "Robert Kim",
    role: "Home Renovation",
    location: "Miami, FL",
    rating: 5,
    text: "From struggling to find clients to booking out 3 months in advance. Game changer for my business."
  },
  {
    name: "Jennifer Davis",
    role: "Pool Services",
    location: "Las Vegas, NV",
    rating: 5,
    text: "Finally stopped chasing leads and started attracting premium clients. Worth every penny invested."
  },
  {
    name: "Carlos Mendez",
    role: "Painting",
    location: "San Antonio, TX",
    rating: 5,
    text: "Went from $50k to $200k annual revenue in 18 months. Their system is absolutely incredible."
  }
];

// Split testimonials into 2 rows
const row1 = testimonials.slice(0, 5); // First 5 testimonials
const row2 = testimonials.slice(5, 9); // Last 4 testimonials
---

<section class="relative py-20 overflow-hidden" style="background-color: #FAF8F5;">
  <div class="max-w-7xl mx-auto px-8 relative z-10">
    
    <!-- Header -->
    <div class="text-center mb-16">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-[#8FA0D8] px-4 py-2 rounded-full border border-[#8FA0D8] mb-6">
        <div class="w-2 h-2 bg-white rounded-full animate-pulse"></div>
        <span class="text-sm font-bold uppercase tracking-widest text-white" style="font-family: 'Poppins', sans-serif;">
          Client Reviews
        </span>
      </div>

      <!-- Main Heading -->
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-[#1B1B1B] mb-6" style="font-family: 'Poppins', sans-serif;">
        <span class="text-[#1B1B1B]">What Our</span>
        <span class="text-[#8FA0D8]"> Clients Say</span>
      </h2>

      <!-- Accent Line -->
      <div class="w-24 h-1 bg-gradient-to-r from-[#8FA0D8] to-[#7A8BD6] rounded-full mx-auto mb-6"></div>

      <!-- Description -->
      <p class="text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed" style="font-family: 'Poppins', sans-serif;">
        Real results from real contractors who transformed their businesses with our proven system
      </p>
    </div>

    <!-- Carousel Rows -->
    <div class="space-y-8">
      
      <!-- Row 1 - Moving Right -->
      <div class="carousel-row overflow-hidden">
        <div class="carousel-track-right flex gap-6" style="animation: scrollRight 40s linear infinite;">
          {[...row1, ...row1].map((testimonial) => (
            <div class="carousel-card flex-shrink-0 w-80">
              <div class="bg-white p-6 rounded-2xl shadow-lg border border-gray-200 h-full">
                <!-- Rating Stars -->
                <div class="flex gap-1 mb-4">
                  {Array.from({ length: testimonial.rating }).map(() => (
                    <span class="text-[#8FA0D8] text-lg">★</span>
                  ))}
                </div>
                
                <!-- Testimonial Text -->
                <blockquote class="text-gray-700 leading-relaxed mb-4" style="font-family: 'Poppins', sans-serif;">
                  "{testimonial.text}"
                </blockquote>
                
                <!-- Customer Info -->
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#8FA0D8] to-[#7A8BD6] flex items-center justify-center text-white font-bold text-sm">
                    {testimonial.name.charAt(0)}
                  </div>
                  <div>
                    <h4 class="font-bold text-[#1B1B1B]" style="font-family: 'Poppins', sans-serif;">{testimonial.name}</h4>
                    <p class="text-sm text-gray-500" style="font-family: 'Poppins', sans-serif;">{testimonial.role}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Row 2 - Moving Left -->
      <div class="carousel-row overflow-hidden">
        <div class="carousel-track-left flex gap-6" style="animation: scrollLeft 35s linear infinite;">
          {[...row2, ...row2, ...row2].map((testimonial) => (
            <div class="carousel-card flex-shrink-0 w-80">
              <div class="bg-white p-6 rounded-2xl shadow-lg border border-gray-200 h-full">
                <!-- Rating Stars -->
                <div class="flex gap-1 mb-4">
                  {Array.from({ length: testimonial.rating }).map(() => (
                    <span class="text-[#8FA0D8] text-lg">★</span>
                  ))}
                </div>
                
                <!-- Testimonial Text -->
                <blockquote class="text-gray-700 leading-relaxed mb-4" style="font-family: 'Poppins', sans-serif;">
                  "{testimonial.text}"
                </blockquote>
                
                <!-- Customer Info -->
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#8FA0D8] to-[#7A8BD6] flex items-center justify-center text-white font-bold text-sm">
                    {testimonial.name.charAt(0)}
                  </div>
                  <div>
                    <h4 class="font-bold text-[#1B1B1B]" style="font-family: 'Poppins', sans-serif;">{testimonial.name}</h4>
                    <p class="text-sm text-gray-500" style="font-family: 'Poppins', sans-serif;">{testimonial.role}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .carousel-row {
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  }

  @keyframes scrollRight {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(0%);
    }
  }

  @keyframes scrollLeft {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  .carousel-track-right:hover,
  .carousel-track-left:hover {
    animation-play-state: paused;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .carousel-card {
      width: 280px;
    }
  }
</style>