---

import Button from '../ui/Button.astro';
import FormInput from '../ui/FormInput.astro';
// Hero2 Component - Modern design inspired by reference with sophisticated gradient
export interface Props {
  eyebrow?: string;
  headline?: string;
  backLink?: string;
  backText?: string;
  showBackLink?: boolean;
  highlightWord?: string;
  description?: string;
  formTitle?: string;
  formButtonText?: string;
  showForm?: boolean;
  variant?: 'default' | 'centered' | 'split' | 'modern';
}

const { 
  eyebrow = "YOUR GROWTH PARTNER",
  headline = "Build. Grow. Dominate.",
  backLink = "/trades-we-serve",
  backText = "Back to Trades",
  showBackLink = false,
  highlightWord = "Grow",
  description = "Over 2,500 contractors and trades professionals have trusted us to elevate their digital presence and drive real results. Transform your business online and reach more customers than ever before.",
  formTitle = "Get Your Free Quote Today",
  formButtonText = "Get Started",
  showForm = true,
  variant = "split"
} = Astro.props;

// Split headline into parts for highlighting
const headlineParts = headline.split(highlightWord);
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Sophisticated dark gradient background matching reference image -->
  <div class="absolute inset-0" style="background: radial-gradient(ellipse at center top, rgba(51, 65, 85, 0.3) 0%, rgba(30, 41, 59, 0.8) 30%, rgba(15, 23, 42, 0.95) 60%, rgba(2, 6, 23, 1) 100%), linear-gradient(180deg, rgba(30, 41, 59, 0.4) 0%, rgba(15, 23, 42, 0.8) 50%, rgba(2, 6, 23, 1) 100%);"></div>
  
  <!-- Subtle animated background elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-[#DC2626]/8 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-[#64748B]/8 rounded-full blur-3xl animate-pulse delay-1000"></div>
    <div class="absolute top-1/2 right-1/3 w-48 h-48 bg-[#2563EB]/6 rounded-full blur-2xl animate-pulse delay-500"></div>
  </div>

  <div class="relative z-10 w-full py-16 pt-[80px]">
    <div class="max-w-7xl mx-auto">
         
      {variant === 'split' ? (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center px-8">
          <!-- Left Content -->
          <div>   
            <!-- Back Link - Top of Section -->
            {showBackLink && backLink && (
              <div class="mb-12">
                <a
                  href={backLink}
                  class="inline-flex items-center gap-3 text-white hover:text-[#DC2626] transition-all duration-300 text-base group bg-black/20 backdrop-blur-md px-6 py-3 rounded-xl border border-[#DC2626]/20 hover:border-[#DC2626]/60 hover:shadow-lg hover:shadow-[#DC2626]/20 hover:bg-black/40"
                >
                  <svg
                    class="w-5 h-5 transition-transform duration-300 group-hover:-translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 19l-7-7 7-7"></path>
                  </svg>
                  {backText}
                </a>
              </div>
            )}         
            <div class="space-y-8">
              <!-- Eyebrow -->
              <div id="hero2-eyebrow" class="inline-block">
                <span class="text-[#DC2626] font-bold font-primary uppercase tracking-[0.2em] text-sm">
                  {eyebrow}
                </span>
              </div>
              
              <!-- Modern subtitle section -->
              <div class="space-y-2">
                <h2 class="text-lg md:text-xl font-medium text-gray-300 tracking-wide">
                  Modern
                </h2>
                <p class="text-base text-gray-400 max-w-md leading-relaxed">
                  Created for you.
                </p>
              </div>

              <!-- CTA Section -->
              <div class="space-y-4 pt-4">
                <div>
                  <h3 class="text-lg font-semibold text-white mb-2 tracking-wide">
                    LIMITED PRE-ORDERS
                  </h3>
                  <p class="text-sm text-gray-400 max-w-sm leading-relaxed">
                    Own the next-generation website engineered for your comfort and bold individuality.
                  </p>
                </div>
                
                <div class="pt-4">
                  <Button
                    variant="outline"
                    size="md"
                    href="/our-work"
                    ariaLabel="View our portfolio of completed projects"
                  >
                    VIEW OUR WORK
                    <svg
                      class="w-4 h-4 ml-2"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                      ></path>
                    </svg>
                  </Button>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Form -->
          {showForm && (
            <div id="hero2-form" class="flex justify-center lg:justify-end">
              <!-- SVG Clip Path Definition -->
              <svg width="0" height="0" class="absolute">
                <defs>
                    <clipPath id="customClip" clipPathUnits="objectBoundingBox">
                        <path d="M 0.040, 0.120 L 0.040, 0.120 Q 0.040, 0.050 0.120, 0.050 L 0.820, 0.050 Q 0.900, 0.050 0.900, 0.110 L 0.900, 0.180 Q 0.900, 0.200 0.920, 0.200 L 0.930, 0.200 Q 0.960, 0.200 0.960, 0.230 L 0.960, 0.870 Q 0.960, 0.950 0.880, 0.950 L 0.130, 0.950 Q 0.090, 0.950 0.090, 0.910 L 0.090, 0.870 Q 0.090, 0.850 0.070, 0.850 L 0.060, 0.850 Q 0.040, 0.850 0.040, 0.830 Z" />
                    </clipPath>
                </defs>
              </svg>

              <div class="relative w-full max-w-2xl">
                <!-- Shadow layer -->
                <div class="absolute inset-0 bg-black/10 transform translate-x-3 translate-y-3 clipped-element"></div>
                
                <!-- Main form with custom clip path -->
                <div class="relative bg-gradient-to-br from-white/98 to-[#F5F5F5]/95 backdrop-blur-sm shadow-2xl border border-[#64748B]/20 clipped-element" >
                  <div class="px-6 md:px-15 lg:px-20 py-8 md:py-24 lg:py-24  flex flex-col">
                    <h2 class="text-4xl md:text-5xl font-bold font-primary mt-5 mb-2 lg:mb-10 leading-tight text-center pr-2 md:pr-0" style="color: #334155;">
                        {formTitle}
                    </h2>
                    
                    <form class="space-y-6" id="hero-form-2">
                      <FormInput 
                        type="text"
                        name="name"
                        label="Name"
                        placeholder="Full Name"
                        variant="dark"
                        required
                      />
                      
                      <FormInput 
                        type="email"
                        name="email"
                        label="Email"
                        placeholder="Email Address"
                        variant="dark"
                        required
                      />
                      
                      <FormInput 
                        type="tel"
                        name="phone"
                        label="Phone"
                        placeholder="Phone Number"
                        variant="dark"
                        required
                      />
                      
                      <!-- Submit Button -->
                      <div class="mb-5 md:mb-0 lg:mb-0 pt-0 md:pt-4 lg:pt-4 flex justify-center">
                          <!-- Mobile: md size -->
                          <div class="block md:hidden">
                              <Button size="md">
                                  {formButtonText}
                              </Button>
                          </div>

                          <!-- Tablet/Desktop: full width -->
                          <div class="hidden md:block w-full">
                              <Button fullWidth>
                                  {formButtonText}
                              </Button>
                          </div>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      ) : variant === 'modern' ? (
        <!-- Modern variant matching reference design -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center min-h-[80vh] px-8">
          
          <!-- Left Content -->
          <div class="lg:col-span-5 space-y-6 animate-[fade-in-left_1s_ease-out]">
            <!-- Small Title -->
            <div class="mb-4">
              <span
                class="inline-block font-semibold tracking-[0.2em] uppercase text-sm"
                style="color: var(--accent-red);"
              >
                {eyebrow}
              </span>
            </div>

            <!-- Subtitle -->
            <div class="space-y-2">
              <h2 class="text-lg md:text-xl font-medium text-gray-300 tracking-wide">
                Modern
              </h2>
              <p class="text-base text-gray-400 max-w-md leading-relaxed">
                Created for you.
              </p>
            </div>

            <!-- CTA Section -->
            <div class="space-y-4 pt-4">
              <div>
                <h3 class="text-lg font-semibold text-white mb-2 tracking-wide">
                  LIMITED PRE-ORDERS
                </h3>
                <p class="text-sm text-gray-400 max-w-sm leading-relaxed">
                  {description}
                </p>
              </div>
              
              <div class="pt-4">
                <Button
                  variant="outline"
                  size="md"
                  href="/our-work"
                  ariaLabel="View our portfolio of completed projects"
                >
                  VIEW OUR WORK
                  <svg
                    class="w-4 h-4 ml-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    ></path>
                  </svg>
                </Button>
              </div>
            </div>
          </div>

          <!-- Center - Large Typography -->
          <div class="lg:col-span-7 flex items-center justify-center relative">
            <!-- Main Heading - Large Background Text -->
            <div class="text-center animate-[fade-in-up_1.2s_ease-out] opacity-0 [animation-delay:0.3s] [animation-fill-mode:forwards]">
              <h1 class="hero-lcp font-black leading-[0.85] tracking-tighter select-none">
                <div class="text-[8rem] md:text-[12rem] lg:text-[16rem] xl:text-[20rem] text-gray-600/20 font-black">
                  BUILD
                </div>
                <div class="text-[6rem] md:text-[9rem] lg:text-[12rem] xl:text-[15rem] -mt-8 md:-mt-12 lg:-mt-16">
                  <span style="color: var(--primary-blue);" class="font-black">GROW</span>
                </div>
                <div class="text-[8rem] md:text-[12rem] lg:text-[16rem] xl:text-[20rem] text-gray-600/20 font-black -mt-8 md:-mt-12 lg:-mt-16">
                  DOMINATE
                </div>
              </h1>
            </div>

            <!-- Floating Central Element -->
            <div class="absolute inset-0 flex items-center justify-center animate-[float_6s_ease-in-out_infinite] opacity-0 [animation-delay:0.8s] [animation-fill-mode:forwards]">
              <div class="relative">
                <!-- Glowing orb effect -->
                <div class="w-32 h-32 md:w-48 md:h-48 rounded-full bg-gradient-to-br from-blue-500/30 to-red-500/30 blur-xl animate-pulse"></div>
                <div class="absolute inset-0 w-32 h-32 md:w-48 md:h-48 rounded-full border-2 border-white/20 backdrop-blur-sm flex items-center justify-center">
                  <div class="w-16 h-16 md:w-24 md:h-24 rounded-full bg-gradient-to-br from-blue-600 to-red-600 shadow-2xl"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Content -->
          <div class="lg:col-span-12 lg:col-start-9 lg:col-end-13 space-y-6 animate-[fade-in-right_1s_ease-out] opacity-0 [animation-delay:0.5s] [animation-fill-mode:forwards]">
            <div class="text-right">
              <h3 class="text-lg font-semibold text-white mb-2 tracking-wide">
                THIS MONTH'S EXCLUSIVE
              </h3>
              <p class="text-sm text-gray-400 max-w-sm ml-auto leading-relaxed">
                Pre-order now and unlock exclusive pricing this month.
              </p>
              
              <div class="pt-4">
                <button class="inline-flex items-center text-sm text-gray-300 hover:text-white transition-colors duration-200 group">
                  See more info
                  <svg class="w-4 h-4 ml-2 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      ) : (
        <!-- Centered variant -->
        <div class="text-center max-w-5xl mx-auto space-y-8 px-8">
          <!-- Eyebrow -->
          <div class="inline-block">
            <span class="text-[#DC2626] font-bold font-primary uppercase tracking-widest" style="font-size: 16px;">
              {eyebrow}
            </span>
          </div>
          
          <!-- Dynamic Headline -->
          <h1 class="text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold font-primary leading-tight text-white">
            {headlineParts[0]}
            <span class="text-[#2563EB] relative">
              {highlightWord}
              <div class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 w-3/4 h-1 bg-[#2563EB] rounded-full"></div>
            </span>
            {headlineParts[1]}
          </h1>
          
          <!-- Description -->
          <p class="leading-relaxed font-primary text-gray-200 max-w-3xl mx-auto" style="font-size: 22px;">
            {description}
          </p>
        </div>
      )}
      
    </div>
  </div>
</section>

<script>
  // Enhanced form handling
  document.getElementById('hero-form-2')?.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const button = this.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = button.textContent;
    
    // Loading state
    button.textContent = 'Sending...';
    button.disabled = true;
    
    const formData = new FormData(this as HTMLFormElement);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      timestamp: new Date().toISOString()
    };
    
    // Simulate API call
    setTimeout(() => {
      console.log('Form submitted:', data);
      
      // Success state
      button.textContent = 'Success!';
      button.classList.add('bg-green-500');
      
      // Reset after 2 seconds
      setTimeout(() => {
        button.textContent = originalText;
        button.disabled = false;
        button.classList.remove('bg-green-500');
        (this as HTMLFormElement).reset();
      }, 2000);
      
      // Show success message
      alert('Thank you! We will contact you within 24 hours.');
    }, 1000);
  });
</script>

<style>
  .clipped-element {
    clip-path: url(#customClip);
  }

  @keyframes fade-in-left {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes fade-in-right {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  /* Responsive typography adjustments */
  @media (max-width: 768px) {
    .hero-lcp div {
      font-size: 4rem !important;
    }
  }

  @media (max-width: 640px) {
    .hero-lcp div {
      font-size: 3rem !important;
    }
  }
</style>