---
interface Props {
    title: string;
    subtitle?: string;
    description?: string;
    image?: string;
    showCTA?: boolean;
    ctaText?: string;
    ctaHref?: string;
}

const {
    title,
    subtitle,
    description,
    image,
    showCTA = false,
    ctaText = "Get Started",
    ctaHref = "/contact",
} = Astro.props;
---

<section class="hero2-section relative overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#161F30] via-[#0F1419] to-[#161F30]"></div>
    
    <!-- Animated Background - Desktop -->
    <div class="hero2-bg-desktop hidden md:block">
        {image ? (
            <div class="absolute inset-0">
                <img 
                    src={image} 
                    alt={title}
                    class="w-full h-full object-cover opacity-20"
                />
                <div class="absolute inset-0 bg-gradient-to-r from-[#161F30] via-[#161F30]/80 to-[#161F30]"></div>
            </div>
        ) : (
            <>
                <!-- Gradient Orbs -->
                <div class="absolute top-20 right-20 w-96 h-96 bg-[#2F8EF8] rounded-full opacity-20 blur-3xl animate-pulse-slow"></div>
                <div class="absolute bottom-20 left-20 w-96 h-96 bg-[#94F9FD] rounded-full opacity-15 blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
            </>
        )}
    </div>

    <!-- Animated Background - Mobile -->
    <div class="hero2-bg-mobile block md:hidden absolute inset-0">
        <!-- Gradient Base -->
        <div class="absolute inset-0 bg-gradient-to-br from-[#161F30] via-[#1a2332] to-[#0F1419]"></div>
        
        <!-- Animated Orbs -->
        <div class="absolute top-10 right-10 w-48 h-48 bg-[#2F8EF8] rounded-full opacity-20 blur-2xl animate-float"></div>
        <div class="absolute bottom-10 left-10 w-48 h-48 bg-[#94F9FD] rounded-full opacity-15 blur-2xl animate-float" style="animation-delay: 1.5s;"></div>
        
        <!-- Diagonal Lines Pattern -->
        <div class="absolute inset-0 opacity-5" style="background-image: repeating-linear-gradient(45deg, #94F9FD 0px, #94F9FD 2px, transparent 2px, transparent 20px);"></div>
    </div>

    <!-- Decorative Top Border -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2F8EF8]/30 to-transparent"></div>

    <!-- Content Container -->
    <div class="relative z-10 max-w-7xl mx-auto px-8 py-12 md:py-16">
        <div class="max-w-4xl mx-auto text-center w-full">
            <!-- Eyebrow Badge -->
            {subtitle && (
                <div class="inline-flex items-center gap-2 bg-gradient-to-r from-[#2F8EF8]/10 to-[#94F9FD]/10 px-4 py-2 rounded-full border border-[#2F8EF8]/20 backdrop-blur-sm mb-6">
                    <div class="w-2 h-2 bg-[#2F8EF8] rounded-full animate-pulse"></div>
                    <span class="text-sm font-bold uppercase tracking-widest text-[#2F8EF8]" style="font-family: 'Poppins', sans-serif;">
                        {subtitle}
                    </span>
                </div>
            )}

            <!-- Main Title -->
            <h1 class="hero2-title text-5xl md:text-6xl lg:text-7xl font-bold mb-6" style="font-family: 'Poppins', sans-serif;">
                {title}
            </h1>

            <!-- Accent Line -->
            <div class="w-24 h-1 bg-gradient-to-r from-[#2F8EF8] to-[#94F9FD] rounded-full mx-auto mb-8"></div>

            <!-- Description -->
            {description && (
                <p class="text-xl md:text-2xl text-gray-300 leading-relaxed mb-10 max-w-3xl mx-auto" style="font-family: 'Poppins', sans-serif;">
                    {description}
                </p>
            )}

            <!-- CTA Button -->
            {showCTA && (
                <a 
                    href={ctaHref}
                    class="inline-flex items-center gap-2 px-8 py-4 bg-[#2F8EF8] hover:bg-[#94F9FD] text-white hover:text-[#161F30] font-semibold rounded-lg transition-all duration-300 shadow-[0_4px_20px_rgba(47,142,248,0.4)] hover:shadow-[0_6px_30px_rgba(148,249,253,0.6)] hover:-translate-y-1"
                    style="font-family: 'Poppins', sans-serif;"
                >
                    {ctaText}
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </a>
            )}
        </div>
    </div>

    <!-- Decorative Bottom Border -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#94F9FD]/30 to-transparent"></div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-6 h-6 text-[#94F9FD]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
    </div>
</section>

<style>
    .hero2-section {
        padding-top: 100px;
    }

    .hero2-title {
        background: linear-gradient(135deg, #FFFFFF 0%, #94F9FD 50%, #2F8EF8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1.2;
        text-shadow: 0 0 40px rgba(148, 249, 253, 0.3);
    }

    @keyframes pulse-slow {
        0%, 100% {
            opacity: 0.2;
            transform: scale(1);
        }
        50% {
            opacity: 0.3;
            transform: scale(1.1);
        }
    }

    @keyframes float {
        0%, 100% {
            transform: translateY(0) translateX(0);
        }
        33% {
            transform: translateY(-20px) translateX(10px);
        }
        66% {
            transform: translateY(10px) translateX(-10px);
        }
    }

    .animate-pulse-slow {
        animation: pulse-slow 4s ease-in-out infinite;
    }

    .animate-float {
        animation: float 6s ease-in-out infinite;
    }

    @media (max-width: 768px) {
        .hero2-section {
            padding-top: 80px;
        }

        .hero2-title {
            font-size: 2.5rem;
        }
    }
</style>
