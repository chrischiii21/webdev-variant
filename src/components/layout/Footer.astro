---
import Button from "../ui/Button.astro";

// Footer component with 4-column layout
---

<footer
  class="bg-gradient-to-br from-[#051219] via-[#0A1931] to-[#0F2847] text-white relative overflow-hidden"
>
  <!-- Subtle background pattern with navy accent -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute bottom-0 left-1/4 w-96 h-96 bg-[#F48C06] rounded-full blur-3xl"
    >
    </div>
  </div>

  <div class="container-custom section-padding relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 px-8">
      <!-- Company Info -->
      <div class="space-y-4">
        <div class="mb-6">
          <a
            href="/"
            class="font-primary font-bold text-2xl text-white hover:text-[#F48C06] transition-colors duration-200 flex items-center gap-3"
          >
            <img
              src="/images/logo.avif"
              alt="BuildPro Logo"
              class="w-[72px] h-auto rounded"
            />
            <span class="text-2xl">
              <span class="text-white">Build</span><span
                style="color: var(--helios-orange);">Pro</span
              >
            </span>
          </a>
        </div>
        <p class="font-primary text-white leading-relaxed">
          Build an elite digital presence that earns customer trust and keeps
          your schedule consistently full.
        </p>
        <div class="space-y-2">
          <p class="font-primary text-white flex items-center">
            <svg
              class="w-4 h-4 mr-2 text-[#F48C06]"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                clip-rule="evenodd"></path>
            </svg>
            123 Main Street, City, State 12345
          </p>
          <a href="tel:+15551234567" class="font-primary text-white hover:!text-[#F48C06] transition-colors duration-200 flex items-center">
            <svg
              class="w-4 h-4 mr-2 text-[#F48C06]"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
              ></path>
            </svg>
            (555) 123-4567
          </a>
          <a href="mailto:info@contractor.com" class="font-primary text-white hover:!text-[#F48C06] transition-colors duration-200 flex items-center">
            <svg
              class="w-4 h-4 mr-2 text-[#F48C06]"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
              ></path>
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
              ></path>
            </svg>
            info@contractor.com
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="space-y-4 md:pl-0 lg:pl-20">
        <h3 class="font-primary font-semibold text-lg text-white mb-6" style="color: #ffffff;">
          Services
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/trades-we-serve/hvac"
              class="font-primary text-white hover:text-[#F48C06] transition-colors duration-200"
            >
              HVAC
            </a>
          </li>
          <li>
            <a
              href="/trades-we-serve/plumbing"
              class="font-primary text-white hover:text-[#F48C06] transition-colors duration-200"
            >
              Plumbing
            </a>
          </li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div class="space-y-4">
        <h3 class="font-primary font-semibold text-lg text-white mb-6" style="color: #ffffff;">
          Quick Links
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="/reviews"
              class="font-primary text-white hover:text-[#F48C06] transition-colors duration-200"
            >
              Reviews
            </a>
          </li>
          <li>
            <a
              href="/our-work"
              class="font-primary text-white hover:text-[#F48C06] transition-colors duration-200"
            >
              Our Work
            </a>
          </li>
          <li>
            <a
              href="/trades-we-serve"
              class="font-primary text-white hover:text-[#F48C06] transition-colors duration-200"
            >
              Trades We Serve
            </a>
          </li>
          <li>
            <a
              href="/what-we-do"
              class="font-primary text-white hover:text-[#F48C06] transition-colors duration-200"
            >
              What We Do
            </a>
          </li>
          <li>
            <a
              href="/contact"
              class="font-primary text-white hover:text-[#F48C06] transition-colors duration-200"
            >
              Contact
            </a>
          </li>
        </ul>
      </div>

      <!-- Socials & Newsletter -->
      <div class="space-y-4">
        <h3 class="font-primary font-semibold text-lg text-white mb-6" style="color: #ffffff;">
          Connect With Us
        </h3>

        <!-- Social Media Links -->
        <div class="flex space-x-4 mb-6">
          <a
            href="#"
            class="text-white hover:text-[#F48C06] transition-colors duration-200"
            aria-label="Follow us on X (Twitter)"
          >
            <svg
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
          <a
            href="#"
            class="text-white hover:text-[#F48C06] transition-colors duration-200"
            aria-label="Follow us on Facebook"
          >
            <svg
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.269h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"
              ></path>
            </svg>
          </a>
          <a
            href="#"
            class="text-white hover:text-[#F48C06] transition-colors duration-200"
            aria-label="Follow us on LinkedIn"
          >
            <svg
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>
          <a
            href="#"
            class="text-white hover:text-[#F48C06] transition-colors duration-200"
            aria-label="Follow us on Pinterest"
          >
            <svg
              class="w-6 h-6"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"
              ></path>
            </svg>
          </a>
        </div>
        <div class="space-y-3">
          <p class="font-primary text-white text-base">
            Have a question or a project in mind? We'd love to hear from you.
          </p>
          <div class="flex grow flex-1">
            <Button variant="primary" size="md" href="/contact" fullWidth theme="light"
              >Get in Touch</Button
            >
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<!-- Bottom Bar -->
<div
  class="bg-gradient-to-r from-[#0A1931] to-[#051219]"
>
  <div class="container-custom py-6 px-8">
    <div
      class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0"
    >
      <p class="font-primary text-[#99B0BB] text-sm">
        © 2026 Contractor Company. All rights reserved.
      </p>
      <div class="flex space-x-6">
        <a
          href="/privacy"
          class="font-primary text-[#99B0BB] hover:text-[#F48C06] text-sm transition-colors duration-200"
        >
          Privacy Policy
        </a>
        <a
          href="/terms"
          class="font-primary text-[#99B0BB] hover:text-[#F48C06] text-sm transition-colors duration-200"
        >
          Terms of Service
        </a>
        <a
          href="/sitemap"
          class="font-primary text-[#99B0BB] hover:text-[#F48C06] text-sm transition-colors duration-200"
        >
          Sitemap
        </a>
      </div>
    </div>
  </div>
</div>
