---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Button from "../ui/Button.astro";
import logoImage from "../../assets/logo.avif";
import { getTradeIcon } from "../../utils/tradeIcons";

const trades = await getCollection("trades");
---

<nav
    class="fixed top-0 w-full z-50 border-b border-[#00C2FF]/20 transition-all duration-300 backdrop-blur-md bg-[#0A0F1E]/80"
    id="navbar"
    style="box-shadow: 0 4px 20px rgba(0, 194, 255, 0.1);"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
            <!-- Logo / Home Link -->
            <div class="shrink-0">
                <a
                    href="/"
                    class="font-primary font-bold text-2xl navbar-logo transition-colors duration-200 flex items-center gap-3"
                >
                    <Image
                        src={logoImage}
                        alt="BuildPro Logo"
                        width={48}
                        height={52}
                        class="w-12 h-auto rounded"
                    />
                    <div>
                        <span class="navbar-logo-build">Build</span><span
                            class="navbar-logo-pro">Pro</span
                        >
                    </div>
                </a>
            </div>

            <!-- Desktop Navigation Links and CTA Button -->
            <div class="hidden lg:flex items-center gap-8">
                <!-- Navigation Links -->
                <div class="flex items-center gap-1">
                    <a
                        href="/reviews"
                        class="navbar-link nav-item text-nav px-3 py-2 transition-colors duration-200 whitespace-nowrap"
                        data-path="/reviews"
                    >
                        Reviews
                    </a>
                    <a
                        href="/our-work"
                        class="navbar-link nav-item text-nav px-3 py-2 transition-colors duration-200 whitespace-nowrap"
                        data-path="/our-work"
                    >
                        Our Work
                    </a>
                    <div class="relative group">
                        <a
                            href="/trades-we-serve"
                            class="navbar-link nav-item text-nav px-3 py-2 transition-colors duration-200 flex items-center whitespace-nowrap"
                            data-path="/trades-we-serve"
                        >
                            Trades We Serve
                            <svg
                                class="ml-1 h-4 w-4 transition-transform duration-200 group-hover:rotate-180"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </a>
                        <!-- Dropdown Menu -->
                        <div
                            class="absolute left-0 mt-2 w-56 bg-[#0A0F1E] rounded-lg shadow-lg border border-[#00C2FF]/30 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
                        >
                            <div class="py-2">
                                {
                                    trades.map((trade) => (
                                        <a
                                            href={`/trades-we-serve/${trade.data.slug}`}
                                            class="flex items-center px-4 py-3 text-white hover:text-[#00C2FF] hover:bg-[#00C2FF]/10 transition-colors duration-200"
                                        >
                                            <svg
                                                class="w-6 h-6 mr-3 shrink-0"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <g
                                                    set:html={getTradeIcon(
                                                        trade.data.name.replace(
                                                            " Services",
                                                            "",
                                                        ),
                                                    )}
                                                />
                                            </svg>
                                            <div>
                                                <div class="font-medium text-white">
                                                    {trade.data.name}
                                                </div>
                                                <div class="text-base text-[#00C2FF]/70">
                                                    {trade.data.tagline}
                                                </div>
                                            </div>
                                        </a>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                    <a
                        href="/what-we-do"
                        class="navbar-link nav-item text-nav px-3 py-2 transition-colors duration-200 whitespace-nowrap"
                        data-path="/what-we-do"
                    >
                        What We Do
                    </a>
                    <a
                        href="/about"
                        class="navbar-link nav-item text-nav px-3 py-2 transition-colors duration-200 whitespace-nowrap"
                        data-path="/about"
                    >
                        About
                    </a>
                </div>

                <!-- CTA Button -->
                <Button
                    variant="urgency"
                    size="md"
                    href="/contact"
                    ariaLabel="Get a quote for your project"
                    scrollAdaptive
                >
                    Get a Quote
                </Button>
            </div>

            <!-- Mobile menu button -->
            <div class="lg:hidden">
                <button
                    type="button"
                    class="burger-btn bg-transparent border-none cursor-pointer p-3 flex flex-col gap-1 items-center rounded-lg transition-colors duration-150 hover:bg-white/10 navbar-link focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#00C2FF]"
                    id="burgerBtn"
                    aria-controls="mobile-menu"
                    aria-expanded="false"
                    aria-label="Toggle navigation menu"
                >
                    <div
                        class="line line-top h-0.5 rounded-sm bg-current transition-all duration-300 ease-out w-3.5"
                    >
                    </div>
                    <div
                        class="line line-middle h-0.5 rounded-sm bg-current transition-all duration-300 ease-out w-6"
                    >
                    </div>
                    <div
                        class="line line-bottom h-0.5 rounded-sm bg-current transition-all duration-300 ease-out w-3.5"
                    >
                    </div>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile menu with smooth slide animation -->
    <div
        class="mobile-menu overflow-hidden transition-all duration-300 ease-in-out max-h-0 lg:hidden"
        id="mobile-menu"
        style="max-height: 0;"
    >
        <div
            class="px-2 pt-2 pb-3 space-y-1 bg-[#0A0F1E] border-t border-[#00C2FF]/30"
        >
            <a
                href="/reviews"
                class="mobile-nav-item text-nav text-white hover:text-[#00C2FF] hover:bg-[#00C2FF]/10 block px-3 py-2 transition-colors duration-200"
                data-path="/reviews">Reviews</a
            >
            <a
                href="/our-work"
                class="mobile-nav-item text-nav text-white hover:text-[#00C2FF] hover:bg-[#00C2FF]/10 block px-3 py-2 transition-colors duration-200"
                data-path="/our-work">Our Work</a
            >
            <div
                class="mobile-nav-item-wrapper flex items-center justify-between w-full"
            >
                <a
                    href="/trades-we-serve"
                    class="mobile-nav-item text-nav text-white hover:text-[#00C2FF] hover:bg-[#00C2FF]/10 px-3 py-2 transition-colors duration-200 flex-1"
                    data-path="/trades-we-serve"
                >
                    Trades We Serve
                </a>
                <button
                    type="button"
                    class="px-3 py-2 text-white hover:text-[#00C2FF] transition-colors duration-200"
                    id="trades-toggle"
                    aria-label="Toggle trades dropdown"
                >
                    <svg
                        class="h-4 w-4 transition-transform duration-200 trades-chevron"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                            clip-rule="evenodd"></path>
                    </svg>
                </button>
            </div>
            <div
                class="mobile-trades-dropdown overflow-hidden transition-all duration-300 ease-in-out bg-[#00C2FF]/10 border-l-4 border-[#00C2FF]"
                style="max-height: 0;"
            >
                {
                    trades.map((trade) => (
                        <a
                            href={`/trades-we-serve/${trade.data.slug}`}
                            class="flex items-center px-6 py-3 text-white hover:text-[#00C2FF] transition-colors duration-200"
                        >
                            <svg
                                class="w-6 h-6 mr-3 shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <g
                                    set:html={getTradeIcon(
                                        trade.data.name.replace(
                                            " Services",
                                            "",
                                        ),
                                    )}
                                />
                            </svg>
                            <div>
                                <div class="font-medium">{trade.data.name}</div>
                                <div class="text-base text-[#00C2FF]/70">
                                    {trade.data.tagline}
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
            <a
                href="/what-we-do"
                class="mobile-nav-item text-nav text-white hover:text-[#00C2FF] hover:bg-[#00C2FF]/10 block px-3 py-2 transition-colors duration-200"
                data-path="/what-we-do">What We Do</a
            >
            <a
                href="/about"
                class="mobile-nav-item text-nav text-white hover:text-[#00C2FF] hover:bg-[#00C2FF]/10 block px-3 py-2 transition-colors duration-200"
                data-path="/about">About</a
            >
            <div class="px-3 py-2">
                <Button
                    variant="urgency"
                    size="md"
                    href="/contact"
                    fullWidth
                    ariaLabel="Get a quote for your project"
                    scrollAdaptive
                >
                    Get a Quote
                </Button>
            </div>
        </div>
    </div>
</nav>

<script src="/src/scripts/script.js"></script>

<style>
    /* Logo colors */
    .navbar-logo-build {
        color: white;
    }

    .navbar-logo-pro {
        color: var(--bright-cyan);
    }

    /* Navigation link colors */
    .navbar-link {
        color: white;
        position: relative;
        transition: all 0.3s ease;
    }

    .navbar-link:hover {
        color: var(--electric-cyan);
        background-color: rgba(0, 194, 255, 0.1);
        border-radius: 0.5rem;
    }

    .navbar-link:hover::after {
        content: "";
        position: absolute;
        bottom: -2px;
        left: 50%;
        transform: translateX(-50%);
        width: 60%;
        height: 2px;
        background: var(--electric-cyan);
        border-radius: 2px;
    }

    /* Active link indicator - Same as hover for consistency */
    .nav-item.active {
        color: var(--electric-cyan);
        background-color: rgba(0, 194, 255, 0.15);
        border-radius: 0.5rem;
        font-weight: 700;
        position: relative;
    }

    .nav-item.active::after {
        content: "";
        position: absolute;
        bottom: -2px;
        left: 50%;
        transform: translateX(-50%);
        width: 80%;
        height: 3px;
        background: linear-gradient(
            90deg,
            transparent,
            var(--electric-cyan),
            transparent
        );
        border-radius: 2px;
    }

    /* Mobile active state */
    .mobile-nav-item.active {
        color: var(--electric-cyan);
        background-color: rgba(0, 194, 255, 0.15);
        border-left: 4px solid var(--electric-cyan);
        font-weight: 700;
    }

    /* Mobile hover state */
    .mobile-nav-item:hover:not(.active) {
        border-left: 4px solid var(--electric-cyan);
        padding-left: calc(0.75rem - 4px);
    }

    /* Dropdown menu styling */
    .group:hover .absolute {
        animation: slideDown 0.2s ease-out;
    }

    @keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Dropdown item hover enhancement */
    .absolute a:hover {
        border-left: 3px solid var(--electric-cyan);
        padding-left: calc(1rem - 3px);
    }

    /* Scrolled navbar state */
    nav.scrolled {
        background: rgba(10, 15, 30, 0.95);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 4px 30px rgba(0, 194, 255, 0.2) !important;
        border-bottom: 1px solid rgba(0, 194, 255, 0.3);
    }

    /* Default navbar glassmorphism */
    nav {
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    /* Burger button animations - flips the line pattern */
    .burger-btn .line-top {
        width: 14px; /* w-3.5 = 14px - starts small */
    }

    .burger-btn .line-middle {
        width: 24px; /* w-6 = 24px - starts long */
    }

    .burger-btn .line-bottom {
        width: 14px; /* w-3.5 = 14px - starts small */
    }

    /* When open: flip the pattern - top and bottom become long, middle becomes short */
    .burger-btn.open .line-top {
        width: 24px; /* becomes long */
    }

    .burger-btn.open .line-middle {
        width: 14px; /* becomes short */
    }

    .burger-btn.open .line-bottom {
        width: 24px; /* becomes long */
    }

    /* Mobile menu open state */
    .mobile-menu.open {
        max-height: 100vh !important;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const navbar = document.querySelector("nav");
        const navItems = document.querySelectorAll(".nav-item");
        const mobileNavItems = document.querySelectorAll(".mobile-nav-item");
        const burgerBtn = document.getElementById("burgerBtn");
        const mobileMenu = document.getElementById("mobile-menu");
        const tradesToggle = document.getElementById("trades-toggle");
        const tradesDropdown = document.querySelector(
            ".mobile-trades-dropdown",
        ) as HTMLElement | null;
        const tradesChevron = document.querySelector(".trades-chevron");

        if (!navbar) return;

        // Burger menu toggle functionality
        if (burgerBtn && mobileMenu) {
            burgerBtn.addEventListener("click", function () {
                const isOpen = mobileMenu.classList.contains("open");

                if (!isOpen) {
                    // Open menu
                    mobileMenu.classList.add("open");
                    burgerBtn.classList.add("open");
                    burgerBtn.setAttribute("aria-expanded", "true");

                    // Calculate and set max height
                    const menuContent = mobileMenu.querySelector(
                        "div",
                    ) as HTMLElement | null;
                    if (menuContent) {
                        mobileMenu.style.maxHeight =
                            menuContent.scrollHeight + "px";
                    }
                } else {
                    // Close menu
                    mobileMenu.classList.remove("open");
                    burgerBtn.classList.remove("open");
                    burgerBtn.setAttribute("aria-expanded", "false");
                    mobileMenu.style.maxHeight = "0";

                    // Also close trades dropdown if open
                    if (tradesDropdown) {
                        tradesDropdown.style.maxHeight = "0px";
                        if (tradesChevron) {
                            tradesChevron.classList.remove("rotate-180");
                        }
                    }
                }
            });

            // Close menu when clicking nav links
            mobileNavItems.forEach((item) => {
                item.addEventListener("click", function () {
                    mobileMenu.classList.remove("open");
                    burgerBtn.classList.remove("open");
                    burgerBtn.setAttribute("aria-expanded", "false");
                    mobileMenu.style.maxHeight = "0";
                });
            });
        }

        // Scroll effect for navbar
        let lastScroll = 0;
        window.addEventListener("scroll", function () {
            const currentScroll = window.pageYOffset;

            if (currentScroll > 50) {
                navbar.classList.add("scrolled");
            } else {
                navbar.classList.remove("scrolled");
            }

            lastScroll = currentScroll;
        });

        // Mobile trades dropdown toggle
        if (tradesToggle && tradesDropdown) {
            // Add transition end listener to update mobile menu height
            tradesDropdown.addEventListener("transitionend", function () {
                const mobileMenu = document.getElementById(
                    "mobile-menu",
                ) as HTMLElement | null;
                if (mobileMenu && mobileMenu.classList.contains("open")) {
                    const menuContent = mobileMenu.querySelector(
                        "div",
                    ) as HTMLElement | null;
                    if (menuContent) {
                        mobileMenu.style.maxHeight =
                            menuContent.scrollHeight + "px";
                    }
                }
            });

            tradesToggle.addEventListener("click", function (e) {
                e.preventDefault();
                e.stopPropagation();

                const dropdown = tradesDropdown;
                const isCurrentlyOpen =
                    dropdown &&
                    dropdown.style.maxHeight &&
                    dropdown.style.maxHeight !== "0px";

                // Toggle dropdown with smooth animation
                if (!isCurrentlyOpen && dropdown) {
                    dropdown.style.maxHeight = dropdown.scrollHeight + "px";
                } else if (dropdown) {
                    dropdown.style.maxHeight = "0px";
                }

                if (tradesChevron) {
                    tradesChevron.classList.toggle("rotate-180");
                }

                // Immediately start expanding mobile menu
                const mobileMenu = document.getElementById(
                    "mobile-menu",
                ) as HTMLElement | null;
                if (mobileMenu && mobileMenu.classList.contains("open")) {
                    requestAnimationFrame(() => {
                        const menuContent = mobileMenu.querySelector(
                            "div",
                        ) as HTMLElement | null;
                        if (menuContent) {
                            mobileMenu.style.maxHeight =
                                menuContent.scrollHeight + "px";
                        }
                    });
                }
            });
        }

        // Close menu when clicking trade links
        const tradeLinks = document.querySelectorAll(
            ".mobile-trades-dropdown a",
        );

        tradeLinks.forEach((link) => {
            link.addEventListener("click", function () {
                if (mobileMenu && burgerBtn) {
                    mobileMenu.classList.remove("open");
                    mobileMenu.style.maxHeight = "0";
                    burgerBtn.classList.remove("open");
                    burgerBtn.setAttribute("aria-expanded", "false");
                }
            });
        });

        function setActiveLink() {
            const currentPath = window.location.pathname;

            // Remove active class from all items
            navItems.forEach((item) => item.classList.remove("active"));
            mobileNavItems.forEach((item) => item.classList.remove("active"));

            // Add active class to matching item
            navItems.forEach((item) => {
                const path = item.getAttribute("data-path");
                if (
                    currentPath === path ||
                    (path === "/" && currentPath === "/")
                ) {
                    item.classList.add("active");
                }
            });

            mobileNavItems.forEach((item) => {
                const path = item.getAttribute("data-path");
                if (
                    currentPath === path ||
                    (path === "/" && currentPath === "/")
                ) {
                    item.classList.add("active");
                }
            });
        }

        // Initial check
        setActiveLink();
    });
</script>
