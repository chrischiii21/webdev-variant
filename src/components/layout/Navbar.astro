---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Button from "../ui/Button.astro";
import logoImage from "../../assets/logo.avif";
import { getTradeIcon } from "../../utils/tradeIcons";

const trades = await getCollection("trades");
---

<nav
    class="sticky top-0 w-full z-50 bg-[#161F30] border-b border-[#94F9FD]/20"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-20">
            <!-- Logo / Home Link -->
            <div class="shrink-0">
                <a
                    href="/"
                    class="font-primary font-bold text-2xl navbar-logo transition-colors duration-200 flex items-center gap-3"
                >
                    <Image
                        src={logoImage}
                        alt="BuildPro Logo"
                        width={48}
                        height={52}
                        class="w-12 h-auto rounded"
                    />
                    <div>
                        <span class="navbar-logo-build">Build</span><span
                            class="navbar-logo-pro">Pro</span
                        >
                    </div>
                </a>
            </div>

            <!-- Desktop Navigation Links and CTA Button -->
            <div class="hidden lg:flex items-center gap-8">
                <!-- Navigation Links -->
                <div class="flex items-center gap-1">
                    <a
                        href="/reviews"
                        class="navbar-link nav-item font-primary px-3 py-2 font-semibold transition-colors duration-200 whitespace-nowrap"
                        style="font-size: 16px;"
                        data-path="/reviews"
                    >
                        Reviews
                    </a>
                    <a
                        href="/our-work"
                        class="navbar-link nav-item font-primary px-3 py-2 font-semibold transition-colors duration-200 whitespace-nowrap"
                        style="font-size: 16px;"
                        data-path="/our-work"
                    >
                        Our Work
                    </a>
                    <div class="relative group">
                        <a
                            href="/trades-we-serve"
                            class="navbar-link nav-item font-primary px-3 py-2 font-semibold transition-colors duration-200 flex items-center whitespace-nowrap"
                            style="font-size: 16px;"
                            data-path="/trades-we-serve"
                        >
                            Trades We Serve
                            <svg
                                class="ml-1 h-4 w-4 transition-transform duration-200 group-hover:rotate-180"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </a>
                        <!-- Dropdown Menu -->
                        <div
                            class="absolute left-0 mt-2 w-56 bg-[#161F30] rounded-lg shadow-lg border border-[#94F9FD]/30 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
                        >
                            <div class="py-2">
                                {
                                    trades.map((trade) => (
                                        <a
                                            href={`/trades-we-serve/${trade.data.slug}`}
                                            class="flex items-center px-4 py-3 text-white hover:text-[#94F9FD] hover:bg-[#94F9FD]/10 transition-colors duration-200"
                                        >
                                            <svg
                                                class="w-6 h-6 mr-3 shrink-0"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <g
                                                    set:html={getTradeIcon(
                                                        trade.data.name.replace(' Services', ''),
                                                    )}
                                                />
                                            </svg>
                                            <div>
                                                <div class="font-medium text-white">
                                                    {trade.data.name}
                                                </div>
                                                <div class="text-base text-[#94F9FD]/70">
                                                    {trade.data.tagline}
                                                </div>
                                            </div>
                                        </a>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                    <a
                        href="/what-we-do"
                        class="navbar-link nav-item font-primary px-3 py-2 font-semibold transition-colors duration-200 whitespace-nowrap"
                        style="font-size: 16px;"
                        data-path="/what-we-do"
                    >
                        What We Do
                    </a>
                    <a
                        href="/about"
                        class="navbar-link nav-item font-primary px-3 py-2 font-semibold transition-colors duration-200 whitespace-nowrap"
                        style="font-size: 16px;"
                        data-path="/about"
                    >
                        About
                    </a>
                </div>

                <!-- CTA Button -->
                <Button
                    variant="primary"
                    size="md"
                    href="/contact"
                    ariaLabel="Get a quote for your project"
                    scrollAdaptive
                >
                    Get a Quote
                </Button>
            </div>

            <!-- Mobile menu button -->
            <div class="lg:hidden">
                <button
                    type="button"
                    class="burger-btn bg-transparent border-none cursor-pointer p-3 flex flex-col gap-1 items-center rounded-lg transition-colors duration-150 hover:bg-white/10 navbar-link focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#94F9FD]"
                    id="burgerBtn"
                    aria-controls="mobile-menu"
                    aria-expanded="false"
                    aria-label="Toggle navigation menu"
                >
                    <div
                        class="line line-top h-0.5 rounded-sm bg-current transition-all duration-300 ease-out w-3.5"
                    >
                    </div>
                    <div
                        class="line line-middle h-0.5 rounded-sm bg-current transition-all duration-300 ease-out w-6"
                    >
                    </div>
                    <div
                        class="line line-bottom h-0.5 rounded-sm bg-current transition-all duration-300 ease-out w-3.5"
                    >
                    </div>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile menu with smooth slide animation -->
    <div
        class="mobile-menu overflow-hidden transition-all duration-300 ease-in-out max-h-0 lg:hidden"
        id="mobile-menu"
        style="max-height: 0;"
    >
        <div
            class="px-2 pt-2 pb-3 space-y-1 bg-[#161F30] border-t border-[#94F9FD]/30"
        >
            <a
                href="/reviews"
                class="mobile-nav-item font-primary text-white hover:text-[#94F9FD] hover:bg-[#94F9FD]/10 block px-3 py-2 font-semibold transition-colors duration-200"
                style="font-size: 15px;"
                data-path="/reviews">Reviews</a
            >
            <a
                href="/our-work"
                class="mobile-nav-item font-primary text-white hover:text-[#94F9FD] hover:bg-[#94F9FD]/10 block px-3 py-2 font-semibold transition-colors duration-200"
                style="font-size: 15px;"
                data-path="/our-work">Our Work</a
            >
            <div
                class="mobile-nav-item-wrapper flex items-center justify-between w-full"
            >
                <a
                    href="/trades-we-serve"
                    class="mobile-nav-item font-primary text-white hover:text-[#94F9FD] hover:bg-[#94F9FD]/10 px-3 py-2 font-semibold transition-colors duration-200 flex-1"
                    style="font-size: 15px;"
                    data-path="/trades-we-serve"
                >
                    Trades We Serve
                </a>
                <button
                    type="button"
                    class="px-3 py-2 text-white hover:text-[#94F9FD] transition-colors duration-200"
                    id="trades-toggle"
                    aria-label="Toggle trades dropdown"
                >
                    <svg
                        class="h-4 w-4 transition-transform duration-200 trades-chevron"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                            clip-rule="evenodd"></path>
                    </svg>
                </button>
            </div>
            <div
                class="mobile-trades-dropdown overflow-hidden transition-all duration-300 ease-in-out bg-[#94F9FD]/10 border-l-4 border-[#94F9FD]"
                style="max-height: 0;"
            >
                {
                    trades.map((trade) => (
                        <a
                            href={`/trades-we-serve/${trade.data.slug}`}
                            class="flex items-center px-6 py-3 text-white hover:text-[#94F9FD] transition-colors duration-200"
                        >
                            <svg
                                class="w-6 h-6 mr-3 shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <g set:html={getTradeIcon(trade.data.name.replace(' Services', ''))} />
                            </svg>
                            <div>
                                <div class="font-medium">
                                    {trade.data.name}
                                </div>
                                <div class="text-base text-[#94F9FD]/70">
                                    {trade.data.tagline}
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
            <a
                href="/what-we-do"
                class="mobile-nav-item font-primary text-white hover:text-[#94F9FD] hover:bg-[#94F9FD]/10 block px-3 py-2 font-semibold transition-colors duration-200"
                style="font-size: 15px;"
                data-path="/what-we-do">What We Do</a
            >
            <a
                href="/about"
                class="mobile-nav-item font-primary text-white hover:text-[#94F9FD] hover:bg-[#94F9FD]/10 block px-3 py-2 font-semibold transition-colors duration-200"
                style="font-size: 15px;"
                data-path="/about">About</a
            >
            <div class="px-3 py-2">
                <Button
                    variant="primary"
                    size="md"
                    href="/contact"
                    fullWidth
                    ariaLabel="Get a quote for your project"
                    scrollAdaptive
                >
                    Get a Quote
                </Button>
            </div>
        </div>
    </div>
</nav>

<script src="/src/scripts/script.js"></script>

<style>
    /* Logo colors */
    .navbar-logo-build {
        color: white;
    }

    .navbar-logo-pro {
        color: var(--bright-cyan);
    }

    /* Navigation link colors */
    .navbar-link {
        color: white;
    }

    .navbar-link:hover {
        color: var(--bright-cyan);
    }

    /* Active link indicator */
    .nav-item.active {
        color: var(--bright-cyan);
    }

    /* Mobile active state */
    .mobile-nav-item.active {
        color: var(--bright-cyan);
        background-color: rgba(148, 249, 253, 0.1);
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const navbar = document.querySelector("nav");
        const navItems = document.querySelectorAll(".nav-item");
        const mobileNavItems = document.querySelectorAll(".mobile-nav-item");
        const tradesToggle = document.getElementById("trades-toggle");
        const tradesDropdown = document.querySelector(
            ".mobile-trades-dropdown",
        );
        const tradesChevron = document.querySelector(".trades-chevron");

        if (!navbar) return;

        // Mobile trades dropdown toggle
        if (tradesToggle && tradesDropdown) {
            // Add transition end listener to update mobile menu height
            tradesDropdown.addEventListener("transitionend", function () {
                const mobileMenu = document.getElementById(
                    "mobile-menu",
                ) as HTMLElement | null;
                if (mobileMenu && mobileMenu.classList.contains("open")) {
                    const menuContent = mobileMenu.querySelector(
                        "div",
                    ) as HTMLElement | null;
                    if (menuContent) {
                        mobileMenu.style.maxHeight =
                            menuContent.scrollHeight + "px";
                    }
                }
            });

            tradesToggle.addEventListener("click", function (e) {
                e.preventDefault();
                e.stopPropagation();

                const dropdown = tradesDropdown as HTMLElement;
                const isCurrentlyOpen =
                    dropdown.style.maxHeight &&
                    dropdown.style.maxHeight !== "0px";

                // Toggle dropdown with smooth animation
                if (!isCurrentlyOpen) {
                    dropdown.style.maxHeight = dropdown.scrollHeight + "px";
                } else {
                    dropdown.style.maxHeight = "0px";
                }

                if (tradesChevron) {
                    tradesChevron.classList.toggle("rotate-180");
                }

                // Immediately start expanding mobile menu
                const mobileMenu = document.getElementById(
                    "mobile-menu",
                ) as HTMLElement | null;
                if (mobileMenu && mobileMenu.classList.contains("open")) {
                    requestAnimationFrame(() => {
                        const menuContent = mobileMenu.querySelector(
                            "div",
                        ) as HTMLElement | null;
                        if (menuContent) {
                            mobileMenu.style.maxHeight =
                                menuContent.scrollHeight + "px";
                        }
                    });
                }
            });
        }

        // Close menu when clicking trade links
        const tradeLinks = document.querySelectorAll(
            ".mobile-trades-dropdown a",
        );
        const burgerBtn = document.getElementById("burgerBtn");
        const mobileMenu = document.getElementById("mobile-menu");

        tradeLinks.forEach((link) => {
            link.addEventListener("click", function () {
                if (mobileMenu && burgerBtn) {
                    mobileMenu.classList.remove("open");
                    mobileMenu.style.maxHeight = "0";
                    burgerBtn.classList.remove("open");
                    burgerBtn.setAttribute("aria-expanded", "false");
                }
            });
        });

        function setActiveLink() {
            const currentPath = window.location.pathname;

            // Remove active class from all items
            navItems.forEach((item) => item.classList.remove("active"));
            mobileNavItems.forEach((item) => item.classList.remove("active"));

            // Add active class to matching item
            navItems.forEach((item) => {
                const path = item.getAttribute("data-path");
                if (
                    currentPath === path ||
                    (path === "/" && currentPath === "/")
                ) {
                    item.classList.add("active");
                }
            });

            mobileNavItems.forEach((item) => {
                const path = item.getAttribute("data-path");
                if (
                    currentPath === path ||
                    (path === "/" && currentPath === "/")
                ) {
                    item.classList.add("active");
                }
            });
        }

        // Initial check
        setActiveLink();
    });
</script>
