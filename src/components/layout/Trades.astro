---
import { getCollection } from "astro:content";
import Card from "../ui/Card.astro";

const trades = await getCollection("trades");
const sortedTrades = trades.sort(
    (a, b) => (a.data.order || 0) - (b.data.order || 0),
);
---

<section
    style="background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%); position: relative; overflow: hidden; padding: 80px 0;"
>
    <!-- Decorative gradients -->
    <div
        style="position: absolute; top: -100px; left: -100px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(37, 99, 235, 0.08) 0%, transparent 70%); pointer-events: none;"
    >
    </div>
    <div
        style="position: absolute; bottom: -100px; right: -100px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(220, 38, 38, 0.06) 0%, transparent 70%); pointer-events: none;"
    >
    </div>

    <div
        style="max-width: 1200px; margin: 0 auto; padding: 0 32px; position: relative; z-index: 1;"
    >
        <!-- Header -->
        <div style="text-align: center; margin-bottom: 60px;">
            <h2
                class="h2"
                style="color: var(--text-charcoal); margin-bottom: 16px;"
            >
                Trades We Serve
            </h2>
            <p
                class="text-description"
                style="color: var(--secondary-gray-blue); max-width: 600px; margin: 0 auto;"
            >
                Specialized solutions tailored for your industry
            </p>
        </div>

        <!-- Cards Grid -->
        <div
            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 32px; margin-bottom: 48px;"
        >
            {
                sortedTrades.map((trade) => (
                    <Card
                        name={trade.data.name}
                        tagline={trade.data.tagline}
                        hoverTitle={trade.data.hoverTitle}
                        hoverDescription={trade.data.hoverDescription}
                        image={trade.data.image}
                        slug={trade.data.slug}
                    />
                ))
            }
        </div>

        <!-- View All Button -->
        <div style="text-align: center;">
            <a
                href="/trades-we-serve"
                class="text-nav"
                style="display: inline-flex; align-items: center; gap: 8px; padding: 16px 32px; background: linear-gradient(135deg, #f97316 0%, #ea580c 100%); color: white; font-weight: 600; border-radius: 12px; text-decoration: none; transition: all 0.3s ease; box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3);"
                onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(249, 115, 22, 0.4)';"
                onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(249, 115, 22, 0.3)';"
            >
                View All Trades
                <svg
                    style="width: 20px; height: 20px;"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
        </div>
    </div>
</section>
