---
import { getCollection } from "astro:content";
import Card from "../ui/Card.astro";

const trades = await getCollection("trades");
const sortedTrades = trades.sort(
    (a, b) => (a.data.order || 0) - (b.data.order || 0),
);
---

<section class="relative py-20">
    <!-- Subtle Section Background -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/5 to-transparent"></div>
    
    <!-- Decorative Section Divider - Top -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#94F9FD]/20 to-transparent"></div>
    
    <!-- Decorative gradients -->
    <div
        class="absolute -top-32 -left-32 w-96 h-96 opacity-10 pointer-events-none"
        style="background: radial-gradient(circle, #94F9FD 0%, transparent 70%);"
    >
    </div>
    <div
        class="absolute -bottom-32 -right-32 w-96 h-96 opacity-8 pointer-events-none"
        style="background: radial-gradient(circle, #2F8EF8 0%, transparent 70%);"
    >
    </div>
    
    <!-- Decorative Section Divider - Bottom -->
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2F8EF8]/20 to-transparent"></div>

    <div class="max-w-7xl mx-auto px-8 relative z-10">
        <!-- Header -->
        <div class="text-center mb-16">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 bg-gradient-to-r from-[#2F8EF8]/10 to-[#94F9FD]/10 px-4 py-2 rounded-full border border-[#94F9FD]/20 mb-6">
                <div class="w-2 h-2 bg-[#94F9FD] rounded-full animate-pulse"></div>
                <span class="text-sm font-bold uppercase tracking-widest text-[#94F9FD]" style="font-family: 'Poppins', sans-serif;">Our Services</span>
            </div>

            <!-- Main Heading -->
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6" style="font-family: 'Poppins', sans-serif;">
                <span class="text-white">Trades We</span> <span class="text-[#94F9FD]">Serve</span>
            </h2>
            
            <!-- Accent Line -->
            <div class="w-24 h-1 bg-gradient-to-r from-[#2F8EF8] to-[#94F9FD] rounded-full mx-auto mb-6"></div>
            
            <!-- Description -->
            <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed" style="font-family: 'Poppins', sans-serif;">
                Specialized solutions tailored for your industry, designed to elevate your business to new heights
            </p>
        </div>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12 max-w-4xl mx-auto">
            {
                sortedTrades.map((trade) => (
                    <Card
                        name={trade.data.name}
                        tagline={trade.data.tagline}
                        hoverTitle={trade.data.hoverTitle}
                        hoverDescription={trade.data.hoverDescription}
                        image={trade.data.image}
                        slug={trade.data.slug}
                    />
                ))
            }
        </div>

        <!-- View All Button -->
        <div class="text-center">
            <a
                href="/trades-we-serve"
                style="display: inline-flex; align-items: center; gap: 8px; padding: 16px 32px; background: linear-gradient(135deg, #f97316 0%, #ea580c 100%); color: white; font-family: var(--font-primary); font-weight: 600; font-size: 1rem; border-radius: 12px; text-decoration: none; transition: all 0.3s ease; box-shadow: 0 4px 12px rgba(249, 115, 22, 0.3);"
                onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(249, 115, 22, 0.4)';"
                onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 12px rgba(249, 115, 22, 0.3)';"
            >
                View All Trades
                <svg
                    style="width: 20px; height: 20px;"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
        </div>
    </div>
</section>
