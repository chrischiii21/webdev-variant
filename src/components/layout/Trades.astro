---
import { getCollection } from "astro:content";
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";

interface Props {
    limit?: number;
}

const { limit } = Astro.props;

const trades = await getCollection("trades");
const sortedTrades = trades.sort(
    (a, b) => (a.data.order || 0) - (b.data.order || 0),
);

// Apply limit if specified
const displayedTrades = limit ? sortedTrades.slice(0, limit) : sortedTrades;
const hasMoreTrades = limit && sortedTrades.length > limit;
---

<section class="relative py-20 overflow-hidden bg-[#161F30]">
    <!-- Subtle Section Background -->
    <div
        class="absolute inset-0 bg-gradient-to-b from-transparent via-black/5 to-transparent"
    >
    </div>

    <!-- Decorative Section Divider - Top -->
    <div
        class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#94F9FD]/20 to-transparent"
    >
    </div>

    <!-- Decorative gradients -->
    <div
        class="absolute -top-32 left-0 w-96 h-96 opacity-10 pointer-events-none"
        style="background: radial-gradient(circle, #94F9FD 0%, transparent 70%);"
    >
    </div>
    <div
        class="absolute -bottom-32 right-0 w-96 h-96 opacity-8 pointer-events-none"
        style="background: radial-gradient(circle, #2F8EF8 0%, transparent 70%);"
    >
    </div>

    <!-- Decorative Section Divider - Bottom -->
    <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2F8EF8]/20 to-transparent"
    >
    </div>

    <div class="max-w-7xl mx-auto px-8 relative z-10">
        <!-- Header -->
        <div class="text-center mb-16">
            <!-- Badge -->
            <div
                class="inline-flex items-center gap-2 bg-gradient-to-r from-[#2F8EF8]/10 to-[#94F9FD]/10 px-4 py-2 rounded-full border border-[#94F9FD]/20 mb-6"
            >
                <div class="w-2 h-2 bg-[#94F9FD] rounded-full animate-pulse">
                </div>
                <span
                    class="text-sm font-bold uppercase tracking-widest text-[#94F9FD]"
                    style="font-family: 'Poppins', sans-serif;"
                    >Our Services</span
                >
            </div>

            <!-- Main Heading -->
            <h2
                class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6"
                style="font-family: 'Poppins', sans-serif;"
            >
                <span class="text-white">Trades We</span>
                <span class="text-[#94F9FD]">Serve</span>
            </h2>

            <!-- Accent Line -->
            <div
                class="w-24 h-1 bg-gradient-to-r from-[#2F8EF8] to-[#94F9FD] rounded-full mx-auto mb-6"
            >
            </div>

            <!-- Description -->
            <p
                class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed"
                style="font-family: 'Poppins', sans-serif;"
            >
                Specialized solutions tailored for your industry, designed to
                elevate your business to new heights
            </p>
        </div>

        <!-- Cards Grid -->
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12 max-w-7xl mx-auto"
        >
            {
                displayedTrades.map((trade) => (
                    <Card
                        name={trade.data.name}
                        tagline={trade.data.tagline}
                        hoverTitle={trade.data.hoverTitle}
                        hoverDescription={trade.data.hoverDescription}
                        image={trade.data.image}
                        slug={trade.data.slug}
                    />
                ))
            }
        </div>

        <!-- View All Button - Show when limit is applied -->
        {
            limit && (
                <div class="text-center">
                    <Button
                        variant="primary"
                        size="lg"
                        href="/trades-we-serve"
                        ariaLabel="View all trades we serve"
                    >
                        View All Trades
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"
                            />
                        </svg>
                    </Button>
                </div>
            )
        }
    </div>
</section>
