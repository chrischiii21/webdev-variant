---
import { getCollection } from "astro:content";
import Button from "../ui/Button.astro";

// Fetch all templates
const allTemplates = await getCollection("templates");

// Group templates by trade and get first template per trade
const templatesByTrade = new Map();
allTemplates
  .sort((a, b) => (a.data.order || 1) - (b.data.order || 1))
  .forEach((template) => {
    const trade = template.data.trade;
    if (!templatesByTrade.has(trade)) {
      templatesByTrade.set(trade, template);
    }
  });

// Convert to array and limit to 6
const featuredTemplates = Array.from(templatesByTrade.values()).slice(0, 6);
---

<section class="relative py-20 overflow-hidden">
  <!-- Subtle Section Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/5 via-transparent to-black/5"></div>

  <!-- Decorative Section Divider - Top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2F8EF8]/20 to-transparent"></div>

  <!-- Decorative gradients -->
  <div
    class="absolute top-20 right-0 w-96 h-96 opacity-10 pointer-events-none"
    style="background: radial-gradient(circle, #2F8EF8 0%, transparent 70%);"
  ></div>
  <div
    class="absolute bottom-20 left-0 w-96 h-96 opacity-8 pointer-events-none"
    style="background: radial-gradient(circle, #94F9FD 0%, transparent 70%);"
  ></div>

  <!-- Decorative Section Divider - Bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#94F9FD]/20 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Header -->
    <div class="text-center mb-16">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-gradient-to-r from-[#94F9FD]/10 to-[#2F8EF8]/10 px-4 py-2 rounded-full border border-[#2F8EF8]/20 mb-6">
        <div class="w-2 h-2 bg-[#2F8EF8] rounded-full animate-pulse"></div>
        <span class="text-sm font-bold uppercase tracking-widest text-[#2F8EF8]" style="font-family: 'Poppins', sans-serif;">
          Our Work
        </span>
      </div>

      <!-- Main Heading -->
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6" style="font-family: 'Poppins', sans-serif;">
        <span class="text-white">Featured</span>
        <span class="text-[#2F8EF8]"> Templates</span>
      </h2>

      <!-- Accent Line -->
      <div class="w-24 h-1 bg-gradient-to-r from-[#94F9FD] to-[#2F8EF8] rounded-full mx-auto mb-6"></div>

      <!-- Description -->
      <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed" style="font-family: 'Poppins', sans-serif;">
        Real results for real contractors. Every project is a case study in market domination.
      </p>
    </div>

    <!-- Templates Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
      {featuredTemplates.map((template, index) => (
        <div class={`template-card group relative overflow-hidden rounded-2xl border-2 border-[#2F8EF8]/30 hover:border-[#94F9FD] transition-all duration-500 ${index === 0 ? 'lg:row-span-2' : ''}`}>
          <!-- Image -->
          <div class={`relative overflow-hidden ${index === 0 ? 'h-[600px]' : 'h-[280px]'}`}>
            <img 
              src={template.data.image || template.data.thumbnail || 'https://images.unsplash.com/photo-1581094271901-8022df4466f9?auto=format&fit=crop&w=800&q=80'} 
              alt={template.data.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
            <!-- Base Gradient Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#161F30] via-[#161F30]/60 to-transparent"></div>
            
            <!-- Glassmorphism Hover Overlay -->
            <div class="template-overlay absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-t from-[#2F8EF8]/45 via-[#2F8EF8]/25 to-[#94F9FD]/15 backdrop-blur-[12px]"></div>
          </div>

          <!-- Default Content - Always Visible -->
          <div class="content-default absolute bottom-0 left-0 right-0 p-8 z-10 opacity-100 group-hover:opacity-0 transition-opacity duration-300 pointer-events-none">
            <!-- Category Badge -->
            <div class="inline-block px-3 py-1 bg-[#2F8EF8]/90 backdrop-blur-sm rounded-full mb-4">
              <span class="text-xs font-bold uppercase tracking-wider text-white" style="font-family: 'Poppins', sans-serif;">
                {template.data.category}
              </span>
            </div>

            <!-- Title -->
            <h3 class="text-2xl md:text-3xl font-bold text-white" style="font-family: 'Poppins', sans-serif;">
              {template.data.title}
            </h3>
          </div>

          <!-- Hover Content - Shows on Hover -->
          <div class="content-expanded absolute bottom-0 left-0 right-0 p-8 z-10 opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500 pointer-events-none group-hover:pointer-events-auto">
            <!-- Category Badge -->
            <div class="inline-block px-3 py-1 bg-[#2F8EF8]/90 backdrop-blur-sm rounded-full mb-4">
              <span class="text-xs font-bold uppercase tracking-wider text-white" style="font-family: 'Poppins', sans-serif;">
                {template.data.category}
              </span>
            </div>

            <!-- Title -->
            <h3 class="text-2xl md:text-3xl font-bold text-white mb-3 group-hover:text-[#94F9FD] transition-colors" style="font-family: 'Poppins', sans-serif;">
              {template.data.title}
            </h3>

            <!-- Description -->
            <p class="text-white mb-4 leading-relaxed text-shadow-lg" style="font-family: 'Poppins', sans-serif;">
              {template.data.description}
            </p>

            <!-- Stats -->
            {template.data.stats && (
              <div class="flex items-center gap-2 mb-4">
                <svg class="w-5 h-5 text-[#94F9FD]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                </svg>
                <span class="text-[#94F9FD] font-semibold" style="font-family: 'Poppins', sans-serif;">
                  {template.data.stats}
                </span>
              </div>
            )}

            <!-- Link -->
            <a 
              href={`/trades-we-serve/${template.data.trade}`}
              class="inline-flex items-center gap-2 text-white hover:text-[#94F9FD] transition-colors group/link"
              style="font-family: 'Poppins', sans-serif;"
            >
              <span class="font-semibold">View Templates</span>
              <svg class="w-5 h-5 transition-transform group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- View All Button - Always visible -->
    <div class="text-center">
      <Button
        variant="primary"
        size="lg"
        href="/our-work"
        ariaLabel="View all our work and case studies"
      >
        View All Projects
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </Button>
    </div>
  </div>
</section>

<style>
  .template-card {
    background: #1b222c;
    box-shadow: 0 4px 20px rgba(47, 142, 248, 0.3);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .template-card:hover {
    transform: translateY(-8px);
    box-shadow:
      0 12px 40px rgba(47, 142, 248, 0.5),
      0 0 30px rgba(148, 249, 253, 0.3);
  }

  .template-overlay {
    -webkit-backdrop-filter: blur(12px);
  }

  .content-default {
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
  }

  .content-expanded {
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
  }

  .text-shadow-lg {
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }
</style>
