---
import { getCollection } from "astro:content";
import Button from "../ui/Button.astro";
import TemplateCard from "../ui/TemplateCard.astro";

// Fetch all templates
const allTemplates = await getCollection("templates");

// Group templates by trade and get first template per trade
const templatesByTrade = new Map();
allTemplates
  .sort((a, b) => (a.data.order || 1) - (b.data.order || 1))
  .forEach((template) => {
    const trade = template.data.trade;
    if (!templatesByTrade.has(trade)) {
      templatesByTrade.set(trade, template);
    }
  });

// Convert to array and limit to 6
const featuredTemplates = Array.from(templatesByTrade.values()).slice(0, 6);
---

<section class="relative py-20 overflow-hidden">
  <!-- Subtle Section Background -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-black/5 via-transparent to-black/5"
  >
  </div>

  <!-- Decorative Section Divider - Top -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2F8EF8]/20 to-transparent"
  >
  </div>

  <!-- Decorative gradients -->
  <div
    class="absolute top-20 right-0 w-96 h-96 opacity-10 pointer-events-none"
    style="background: radial-gradient(circle, #2F8EF8 0%, transparent 70%);"
  >
  </div>
  <div
    class="absolute bottom-20 left-0 w-96 h-96 opacity-8 pointer-events-none"
    style="background: radial-gradient(circle, #94F9FD 0%, transparent 70%);"
  >
  </div>

  <!-- Decorative Section Divider - Bottom -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#94F9FD]/20 to-transparent"
  >
  </div>

  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Header -->
    <div class="text-center mb-16">
      <!-- Badge -->
      <div
        class="inline-flex items-center gap-2 bg-gradient-to-r from-[#94F9FD]/10 to-[#2F8EF8]/10 px-4 py-2 rounded-full border border-[#2F8EF8]/20 mb-6"
      >
        <div class="w-2 h-2 bg-[#2F8EF8] rounded-full animate-pulse"></div>
        <span
          class="text-sm font-bold uppercase tracking-widest text-[#2F8EF8]"
          style="font-family: 'Poppins', sans-serif;"
        >
          Our Work
        </span>
      </div>

      <!-- Main Heading -->
      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6"
        style="font-family: 'Poppins', sans-serif;"
      >
        <span class="text-white">Featured</span>
        <span class="text-[#2F8EF8]"> Templates</span>
      </h2>

      <!-- Accent Line -->
      <div
        class="w-24 h-1 bg-gradient-to-r from-[#94F9FD] to-[#2F8EF8] rounded-full mx-auto mb-6"
      >
      </div>

      <!-- Description -->
      <p
        class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed"
        style="font-family: 'Poppins', sans-serif;"
      >
        Real results for real contractors. Every project is a case study in
        market domination.
      </p>
    </div>

    <!-- Templates Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
      {
        featuredTemplates.map((template, index) => (
          <TemplateCard
            title={template.data.title}
            category={template.data.category}
            description={template.data.description}
            image={template.data.image || template.data.thumbnail}
            stats={template.data.stats}
            href={`/trades-we-serve/${template.data.trade}`}
            linkText="View All Templates"
            featured={index === 0}
          />
        ))
      }
    </div>

    <!-- View All Button - Always visible -->
    <div class="text-center">
      <Button
        variant="primary"
        size="lg"
        href="/our-work"
        ariaLabel="View all our work and case studies"
      >
        View All Projects
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </Button>
    </div>
  </div>
</section>
