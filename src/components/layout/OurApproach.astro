---
const approaches = [
  {
    step: "01",
    title: "Discovery & Analysis",
    description: "We dive deep into your business, analyzing your market position, competition, and unique value propositions to create a tailored strategy.",
    icon: "discovery",
    color: "from-[#8FA0D8] to-[#8FA0D8]"
  },
  {
    step: "02", 
    title: "Strategic Planning",
    description: "Our team develops a comprehensive roadmap with clear milestones, timelines, and measurable goals aligned with your business objectives.",
    icon: "planning",
    color: "from-[#8FA0D8] to-[#8FA0D8]"
  },
  {
    step: "03",
    title: "Design & Development",
    description: "We craft pixel-perfect designs and build lightning-fast, conversion-optimized websites that reflect your brand and drive results.",
    icon: "development",
    color: "from-[#8FA0D8] to-[#8FA0D8]"
  },
  {
    step: "04",
    title: "Launch & Optimize",
    description: "After thorough testing, we launch your project and continuously monitor performance, making data-driven optimizations for maximum ROI.",
    icon: "launch",
    color: "from-[#8FA0D8] to-[#8FA0D8]"
  }
];
---

<section class="relative text-white py-24 px-6 md:px-20 overflow-hidden" style="font-family: 'Roboto', sans-serif;">
  <!-- Dynamic Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#0B0829] via-[#1F2937] to-[#0B0829]"></div>
  <div class="absolute inset-0 bg-gradient-to-tr from-[#8FA0D8]/5 via-transparent to-[#8FA0D8]/5"></div>
  
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <!-- Floating Hexagons -->
    <div class="absolute top-20 left-10 w-24 h-24 border-2 border-[#8FA0D8]/20 rotate-12 animate-float-slow" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
    <div class="absolute bottom-32 right-16 w-16 h-16 border-2 border-[#8FA0D8]/30 -rotate-12 animate-float-delayed" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"></div>
    
    <!-- Gradient Orbs -->
    <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-gradient-to-r from-[#8FA0D8]/10 to-[#8FA0D8]/10 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 left-1/4 w-80 h-80 bg-gradient-to-r from-[#8FA0D8]/10 to-[#8FA0D8]/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>
  </div>

  <!-- Decorative Section Dividers -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#8FA0D8]/40 to-transparent"></div>
  <div class="absolute top-0 left-1/3 right-1/3 h-1 bg-gradient-to-r from-transparent via-[#8FA0D8]/80 to-transparent blur-sm"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    
    <!-- Header Section -->
    <div class="text-center mb-20">
      <!-- Animated Badge -->
      <div class="inline-flex items-center gap-3 bg-gradient-to-r from-[#8FA0D8]/10 to-[#8FA0D8]/10 px-8 py-4 rounded-full border border-[#8FA0D8]/30 mb-8 backdrop-blur-sm">
        <div class="flex gap-1">
          <div class="w-2 h-2 bg-[#8FA0D8] rounded-full animate-bounce" style="animation-delay: 0s;"></div>
          <div class="w-2 h-2 bg-[#8FA0D8] rounded-full animate-bounce" style="animation-delay: 0.1s;"></div>
          <div class="w-2 h-2 bg-[#8FA0D8] rounded-full animate-bounce" style="animation-delay: 0.2s;"></div>
          <div class="w-2 h-2 bg-[#8FA0D8] rounded-full animate-bounce" style="animation-delay: 0.3s;"></div>
        </div>
        <span class="text-sm font-bold uppercase tracking-widest text-[#8FA0D8]">Our Approach</span>
      </div>

      <!-- Main Heading -->
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-8">
        <span class="text-white">How We</span>
        <span class="block bg-gradient-to-r from-[#8FA0D8] via-[#8FA0D8] to-[#8FA0D8] bg-clip-text text-transparent animate-gradient-x">
          Transform Businesses
        </span>
      </h2>

      <!-- Subtitle -->
      <p class="text-xl text-gray-300 max-w-4xl mx-auto leading-relaxed">
        Our proven methodology combines strategic thinking, creative design, and technical excellence to deliver exceptional results that drive real business growth.
      </p>
    </div>

    <!-- Approach Timeline -->
    <div class="relative">
      <!-- Central Timeline Line -->
      <div class="hidden lg:block absolute left-1/2 top-0 bottom-0 w-1 bg-gradient-to-b from-[#8FA0D8] via-[#8FA0D8] to-[#8FA0D8] transform -translate-x-1/2 rounded-full"></div>
      
      <!-- Approach Steps -->
      <div class="space-y-16 lg:space-y-24">
        {approaches.map((approach, index) => (
          <div class={`relative flex flex-col lg:flex-row items-center gap-8 lg:gap-16 ${
            index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'
          }`}>
            
            <!-- Timeline Node (Desktop) -->
            <div class="hidden lg:block absolute left-1/2 top-1/2 transform -translate-x-1/2 -translate-y-1/2 z-20">
              <div class="w-16 h-16 rounded-full bg-gradient-to-br from-[#0B0829] to-[#1F2937] border-4 border-[#8FA0D8] flex items-center justify-center shadow-2xl">
                <div class="w-6 h-6 rounded-full bg-gradient-to-br from-[#8FA0D8] to-[#8FA0D8] animate-pulse"></div>
              </div>
            </div>

            <!-- Content Card -->
            <div class={`flex-1 ${index % 2 === 0 ? 'lg:pr-16' : 'lg:pl-16'}`}>
              <div class="group relative bg-gradient-to-br from-[#1F2937]/80 to-[#0B0829]/80 backdrop-blur-sm p-8 lg:p-10 rounded-[32px] border border-[#8FA0D8]/20 hover:border-[#8FA0D8]/50 transition-all duration-500 hover:-translate-y-2 shadow-xl hover:shadow-2xl">
                
                <!-- Hover Glow Effect -->
                <div class="absolute inset-0 rounded-[32px] bg-gradient-to-br from-[#8FA0D8]/5 to-[#8FA0D8]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                
                <!-- Step Number -->
                <div class="relative mb-6">
                  <div class={`inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br ${approach.color} text-white text-2xl font-bold shadow-lg group-hover:scale-110 transition-transform duration-500`}>
                    {approach.step}
                  </div>
                </div>

                <!-- Content -->
                <div class="relative">
                  <h3 class="text-3xl font-bold text-white mb-4 group-hover:text-[#8FA0D8] transition-colors duration-300">
                    {approach.title}
                  </h3>
                  <p class="text-lg text-gray-300 leading-relaxed group-hover:text-gray-200 transition-colors duration-300">
                    {approach.description}
                  </p>
                </div>

                <!-- Decorative Elements -->
                <div class="absolute top-6 right-6 w-12 h-12 border-t-2 border-r-2 border-[#8FA0D8]/20 rounded-tr-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute bottom-6 left-6 w-12 h-12 border-b-2 border-l-2 border-[#8FA0D8]/20 rounded-bl-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              </div>
            </div>

            <!-- Icon Section -->
            <div class={`flex-1 ${index % 2 === 0 ? 'lg:pl-16' : 'lg:pr-16'}`}>
              <div class="relative group">
                <!-- Icon Container -->
                <div class="w-32 h-32 mx-auto rounded-3xl bg-gradient-to-br from-[#1F2937]/60 to-[#0B0829]/60 backdrop-blur-sm border border-[#8FA0D8]/30 flex items-center justify-center group-hover:scale-105 transition-all duration-500 shadow-xl">
                  
                  {approach.icon === "discovery" && (
                    <svg class="w-16 h-16 text-[#8FA0D8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                  )}
                  {approach.icon === "planning" && (
                    <svg class="w-16 h-16 text-[#8FA0D8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                    </svg>
                  )}
                  {approach.icon === "development" && (
                    <svg class="w-16 h-16 text-[#8FA0D8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                    </svg>
                  )}
                  {approach.icon === "launch" && (
                    <svg class="w-16 h-16 text-[#8FA0D8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  )}
                  
                  <!-- Floating Particles -->
                  <div class="absolute -top-2 -right-2 w-4 h-4 bg-[#8FA0D8] rounded-full animate-ping"></div>
                  <div class="absolute -bottom-2 -left-2 w-3 h-3 bg-[#8FA0D8] rounded-full animate-ping" style="animation-delay: 1s;"></div>
                </div>

                <!-- Connecting Line to Timeline (Desktop) -->
                <div class={`hidden lg:block absolute top-1/2 ${
                  index % 2 === 0 ? 'right-0 translate-x-8' : 'left-0 -translate-x-8'
                } w-8 h-px bg-gradient-to-r from-[#8FA0D8]/50 to-transparent transform -translate-y-1/2`}></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="mt-20 text-center">
      <div class="inline-flex items-center gap-4 bg-gradient-to-r from-[#1F2937]/60 to-[#0B0829]/60 backdrop-blur-sm px-10 py-6 rounded-full border border-[#8FA0D8]/30 hover:border-[#8FA0D8]/60 transition-all duration-300 group">
        <div class="flex items-center gap-2">
          <div class="w-4 h-4 bg-[#8FA0D8] rounded-full animate-pulse"></div>
          <div class="w-4 h-4 bg-[#8FA0D8] rounded-full animate-pulse" style="animation-delay: 0.5s;"></div>
        </div>
        <span class="text-[#8FA0D8] font-semibold text-lg">Ready to start your transformation?</span>
        <a href="/contact" class="text-white hover:text-[#8FA0D8] transition-colors duration-300 font-bold text-lg group-hover:translate-x-1 transform transition-transform">
          Let's Begin →
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Decorative Dividers -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#8FA0D8]/40 to-transparent"></div>
  <div class="absolute bottom-0 left-1/3 right-1/3 h-1 bg-gradient-to-r from-transparent via-[#8FA0D8]/80 to-transparent blur-sm"></div>
</section>

<style>
  @keyframes float-slow {
    0%, 100% { transform: translateY(0) rotate(12deg); }
    50% { transform: translateY(-15px) rotate(12deg); }
  }

  @keyframes float-delayed {
    0%, 100% { transform: translateY(0) rotate(-12deg); }
    50% { transform: translateY(15px) rotate(-12deg); }
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }

  @keyframes gradient-x {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .animate-float-slow {
    animation: float-slow 6s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float-delayed 8s ease-in-out infinite;
  }

  .animate-pulse-slow {
    animation: pulse-slow 4s ease-in-out infinite;
  }

  .animate-gradient-x {
    background-size: 200% 200%;
    animation: gradient-x 3s ease infinite;
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .space-y-16 {
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .space-y-16 {
      gap: 2rem;
    }
  }
</style>