---
const stats = [
  { number: "500+", label: "Projects Completed", icon: "briefcase" },
  { number: "98%", label: "Client Satisfaction", icon: "heart" },
  { number: "15+", label: "Years Experience", icon: "clock" },
  { number: "50+", label: "Team Members", icon: "users" },
];
---

<section
  class="relative text-white py-20 overflow-hidden"
  style="font-family: 'Poppins', sans-serif;"
>
  <!-- Subtle Section Background with Glass Effect -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/10 to-transparent"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-[#94F9FD]/5 via-transparent to-[#2F8EF8]/5"></div>

  <!-- Animated Background Orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div
      class="absolute top-1/4 -left-20 w-96 h-96 bg-[#2F8EF8]/10 rounded-full blur-3xl animate-float"
    >
    </div>
    <div
      class="absolute bottom-1/4 -right-20 w-96 h-96 bg-[#94F9FD]/10 rounded-full blur-3xl animate-float-delayed"
    >
    </div>
  </div>

  <!-- Decorative Section Divider - Top -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2F8EF8]/30 to-transparent"
  >
  </div>
  <div class="absolute top-0 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-transparent via-[#2F8EF8]/60 to-transparent blur-sm"></div>

  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Diagonal Split Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Left Side - Stacked Stats with Diagonal Offset -->
      <div class="lg:col-span-5 space-y-6">
        <!-- Header Badge -->
        <div
          class="inline-flex items-center gap-2 bg-gradient-to-r from-[#94F9FD]/10 to-[#2F8EF8]/10 px-4 py-2 rounded-full border border-[#94F9FD]/20 mb-2"
        >
          <div class="w-2 h-2 bg-[#94F9FD] rounded-full animate-pulse"></div>
          <span
            class="text-xs font-bold uppercase tracking-widest text-[#94F9FD]"
            >By The Numbers</span
          >
        </div>

        <!-- Main Heading -->
        <h2
          class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-8"
        >
          <span class="text-white">Proven Track</span><br />
          <span class="text-white">Record of</span>
          <span class="text-[#94F9FD]">Excellence.</span>
        </h2>

        <!-- Diagonal Stat Cards -->
        <div class="space-y-5">
          {
            stats.slice(0, 2).map((stat, index) => (
              <div
                class="stat-card-diagonal group bg-[#1B222C] border-2 border-[#2F8EF8]/30 rounded-3xl p-6 hover:border-[#94F9FD] transition-all duration-500 transform hover:-translate-y-2"
                style={`transform: translateX(${index * 20}px);`}
              >
                <div class="flex items-center justify-between">
                  <div>
                    <div class="stat-number text-3xl md:text-4xl font-bold mb-1">
                      {stat.number}
                    </div>
                    <p class="text-gray-400 text-xs uppercase tracking-wider">
                      {stat.label}
                    </p>
                  </div>
                  <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-[#2F8EF8]/20 to-[#94F9FD]/20 flex items-center justify-center group-hover:rotate-12 transition-transform duration-500 shrink-0">
                    {stat.icon === "briefcase" && (
                      <svg
                        class="w-7 h-7 text-[#94F9FD]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        />
                      </svg>
                    )}
                    {stat.icon === "heart" && (
                      <svg
                        class="w-7 h-7 text-[#94F9FD]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                        />
                      </svg>
                    )}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Center - Vertical Divider with Animated Pulse -->
      <div class="hidden lg:flex lg:col-span-2 justify-center items-center">
        <div class="relative h-80">
          <div
            class="absolute inset-0 w-px bg-gradient-to-b from-transparent via-[#94F9FD]/50 to-transparent"
          >
          </div>
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-[#94F9FD] rounded-full animate-ping"
          >
          </div>
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-4 h-4 bg-[#94F9FD] rounded-full"
          >
          </div>
        </div>
      </div>

      <!-- Right Side - Stacked Stats with Opposite Diagonal -->
      <div class="lg:col-span-5 space-y-6">
        <div class="space-y-5">
          {
            stats.slice(2, 4).map((stat, index) => (
              <div
                class="stat-card-diagonal group bg-[#1B222C] border-2 border-[#2F8EF8]/30 rounded-3xl p-6 hover:border-[#94F9FD] transition-all duration-500 transform hover:-translate-y-2"
                style={`transform: translateX(-${index * 20}px);`}
              >
                <div class="flex items-center justify-between">
                  <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-[#2F8EF8]/20 to-[#94F9FD]/20 flex items-center justify-center group-hover:rotate-12 transition-transform duration-500 shrink-0">
                    {stat.icon === "clock" && (
                      <svg
                        class="w-7 h-7 text-[#94F9FD]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                        />
                      </svg>
                    )}
                    {stat.icon === "users" && (
                      <svg
                        class="w-7 h-7 text-[#94F9FD]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                        />
                      </svg>
                    )}
                  </div>
                  <div class="text-right">
                    <div class="stat-number text-3xl md:text-4xl font-bold mb-1">
                      {stat.number}
                    </div>
                    <p class="text-gray-400 text-xs uppercase tracking-wider">
                      {stat.label}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- CTA Card -->
        <div
          class="mt-6 bg-gradient-to-br from-[#2F8EF8]/10 to-[#94F9FD]/10 border-2 border-[#94F9FD]/30 rounded-3xl p-6 backdrop-blur-sm"
        >
          <p class="text-white text-base mb-4 leading-relaxed">
            Ready to see what we can achieve together?
          </p>
          <a
            href="/contact"
            class="inline-flex items-center gap-3 bg-gradient-to-r from-[#2F8EF8] to-[#94F9FD] hover:from-[#94F9FD] hover:to-[#2F8EF8] text-white px-6 py-3 rounded-full font-bold transition-all duration-300 hover:scale-105 hover:shadow-xl group"
          >
            <span>Start Your Project</span>
            <svg
              class="w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Floating Stats Bar -->
    <div class="mt-16">
      <div
        class="bg-[#1B222C] border-2 border-[#2F8EF8]/30 rounded-full p-5 flex flex-wrap justify-around items-center gap-6 hover:border-[#94F9FD] transition-all duration-500"
      >
        <div class="flex items-center gap-3">
          <div
            class="w-12 h-12 rounded-full bg-gradient-to-br from-[#2F8EF8] to-[#94F9FD] flex items-center justify-center shrink-0"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <div>
            <p class="text-[#94F9FD] font-bold text-base">Fast Delivery</p>
            <p class="text-gray-400 text-xs">On-Time Completion</p>
          </div>
        </div>

        <div class="hidden md:block w-px h-10 bg-[#2F8EF8]/30"></div>

        <div class="flex items-center gap-3">
          <div
            class="w-12 h-12 rounded-full bg-gradient-to-br from-[#94F9FD] to-[#2F8EF8] flex items-center justify-center shrink-0"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
          </div>
          <div>
            <p class="text-[#94F9FD] font-bold text-base">Quality Assured</p>
            <p class="text-gray-400 text-xs">Premium Standards</p>
          </div>
        </div>

        <div class="hidden md:block w-px h-10 bg-[#2F8EF8]/30"></div>

        <div class="flex items-center gap-3">
          <div
            class="w-12 h-12 rounded-full bg-gradient-to-br from-[#2F8EF8] to-[#94F9FD] flex items-center justify-center shrink-0"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <div>
            <p class="text-[#94F9FD] font-bold text-base">24/7 Support</p>
            <p class="text-gray-400 text-xs">Always Available</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Decorative Section Divider - Bottom -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#94F9FD]/30 to-transparent"
  >
  </div>
  <div class="absolute bottom-0 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-transparent via-[#94F9FD]/60 to-transparent blur-sm"></div>
</section>

<style>
  .stat-card-diagonal {
    box-shadow: 0 4px 20px rgba(47, 142, 248, 0.3);
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .stat-card-diagonal:hover {
    box-shadow: 0 12px 40px rgba(148, 249, 253, 0.4);
  }

  .stat-number {
    background: linear-gradient(135deg, #94f9fd 0%, #2f8ef8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-20px) scale(1.05);
    }
  }

  @keyframes float-delayed {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(20px) scale(1.05);
    }
  }

  .animate-float {
    animation: float 8s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float-delayed 8s ease-in-out infinite;
    animation-delay: 2s;
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .stat-card-diagonal {
      transform: translateX(0) !important;
    }
  }
</style>
