---

---

<section
  class="bg-[#111827] text-white py-16 px-6 md:px-20 font-sans"
  style="font-family: 'Poppins', sans-serif;"
>
  <div
    class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
  >
    <!-- Left Column - Images and Stats -->
    <div class="relative grid grid-cols-2 gap-4">
      <!-- Years of Experience Badge -->
      <div
        class="absolute -top-6 -left-6 bg-[#111827] p-4 rounded-2xl z-10 border border-gray-800"
      >
        <h2
          class="text-[#2563EB] text-4xl font-bold"
          style="font-family: 'Poppins', sans-serif;"
        >
          15+
        </h2>
        <p
          class="text-gray-400 text-sm"
          style="font-family: 'Poppins', sans-serif;"
        >
          Years Of Experience
        </p>
      </div>

      <!-- Top Left Image -->
      <div class="space-y-4">
        <img
          src="https://images.unsplash.com/photo-1541888946425-d81bb19480c5?auto=format&fit=crop&w=600&q=80"
          alt="Engineer"
          class="rounded-t-[100px] rounded-b-3xl w-full h-[350px] object-cover"
        />
      </div>

      <!-- Bottom Section - Image and Rating Card -->
      <div class="space-y-4 mt-12">
        <img
          src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=600&q=80"
          alt="Architect"
          class="rounded-t-3xl rounded-b-[30px] w-full h-[300px] object-cover"
        />

        <!-- Customer Rating Card -->
        <div class="bg-[#1F2937] p-6 rounded-3xl border border-gray-700">
          <p
            class="font-semibold text-lg"
            style="font-family: 'Poppins', sans-serif;"
          >
            Customer Rating
          </p>
          <div class="flex items-center gap-2 my-2">
            <span class="text-[#2563EB]">★</span>
            <span class="text-sm" style="font-family: 'Poppins', sans-serif;"
              >4.9 (40K Reviews)</span
            >
          </div>
          <div class="flex -space-x-3 mt-4">
            <img
              class="w-10 h-10 rounded-full border-2 border-gray-800"
              src="https://i.pravatar.cc/100?u=1"
              alt="Customer 1"
            />
            <img
              class="w-10 h-10 rounded-full border-2 border-gray-800"
              src="https://i.pravatar.cc/100?u=2"
              alt="Customer 2"
            />
            <img
              class="w-10 h-10 rounded-full border-2 border-gray-800"
              src="https://i.pravatar.cc/100?u=3"
              alt="Customer 3"
            />
            <div
              class="w-10 h-10 rounded-full bg-[#2563EB] flex items-center justify-center text-white border-2 border-gray-800"
              style="font-family: 'Poppins', sans-serif;"
            >
              +
            </div>
          </div>
        </div>
      </div>

      <!-- Building Icon Badge -->
      <div
        class="absolute bottom-10 left-1/2 -translate-x-1/2 bg-[#2563EB] p-4 rounded-2xl shadow-lg"
      >
        <svg
          class="w-6 h-6 text-white"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </div>
    </div>

    <!-- Right Column - Content -->
    <div class="lg:pl-10">
      <!-- Header Badge -->
      <div class="flex items-center gap-2 text-[#2563EB] mb-4">
        <span class="text-eyebrow">Who We Are</span>
      </div>

      <!-- Main Heading -->
      <h1 class="h1 mb-6">
        Creating Spaces That <br /> Inspire Everyday Life.
      </h1>

      <!-- Description -->
      <p class="text-description text-gray-400 mb-10">
        Our company focuses on designing and building remarkable properties that
        combine functionality and aesthetics. We believe in integrity,
        innovation.
      </p>

      <!-- Vision and Mission Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
        <!-- Our Vision Card -->
        <div class="bg-[#1F2937] p-6 rounded-3xl border border-gray-700">
          <div
            class="bg-[#2563EB] w-12 h-12 rounded-full flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path
                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3 class="h3 mb-2">Our Vision</h3>
          <p class="text-nav text-gray-400">
            To create exceptional projects that combine quality, design, and
            trust for all our clients.
          </p>
        </div>

        <!-- Our Mission Card -->
        <div class="bg-[#1F2937] p-6 rounded-3xl border border-gray-700">
          <div
            class="bg-[#2563EB] w-12 h-12 rounded-full flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <h3 class="h3 mb-2">Our Mission</h3>
          <p class="text-nav text-gray-400">
            Building high-quality, sustainable projects that exceed client
            expectations.
          </p>
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-wrap items-center gap-8">
        <a
          href="#"
          class="bg-[#2563EB] hover:bg-[#1d4ed8] text-white px-8 py-4 rounded-full font-bold flex items-center gap-2 transition"
          style="font-family: 'Poppins', sans-serif;"
        >
          View All Services
          <span
            class="bg-white text-[#2563EB] rounded-full w-6 h-6 flex items-center justify-center text-xs"
            >↗</span
          >
        </a>
        <div class="flex items-center gap-4">
          <div class="bg-[#2563EB] p-3 rounded-full">
            <svg
              class="w-5 h-5 text-white"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
              ></path>
            </svg>
          </div>
          <div>
            <p
              class="text-gray-400 text-xs"
              style="font-family: 'Poppins', sans-serif;"
            >
              Call Us
            </p>
            <p class="font-bold" style="font-family: 'Poppins', sans-serif;">
              +(123) 456 78910
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .statistics-section {
    font-family: "Poppins", sans-serif;
  }

  .statistics-section * {
    font-family: "Poppins", sans-serif !important;
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .statistics-section .grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* Smooth transitions */
  .statistics-section a {
    transition: all 0.3s ease;
  }

  .statistics-section a:hover {
    transform: translateY(-2px);
  }
</style>
