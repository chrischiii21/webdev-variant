---
---

<section class="relative text-white py-16 font-sans" style="font-family: 'Poppins', sans-serif;">
  <!-- Subtle Section Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/5 via-transparent to-black/5"></div>
  
  <!-- Decorative Section Divider - Top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2F8EF8]/20 to-transparent"></div>
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center px-8">
    
    <!-- Left Column - Images and Stats -->
    <div class="relative flex flex-col justify-center">
      
      <!-- Years of Experience Badge -->
      <div class="absolute top-0 left-0 bg-[#161F30] p-6 rounded-2xl z-10 border border-[#94F9FD]/30">
        <h2 class="text-[#94F9FD] text-4xl font-bold" style="font-family: 'Poppins', sans-serif;">15+</h2>
        <p class="text-gray-400 text-sm" style="font-family: 'Poppins', sans-serif;">Years Of Experience</p>
      </div>

      <!-- Second Image -->
      <div class="flex justify-center mb-8">
        <img 
          src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=600&q=80" 
          alt="Architect" 
          class="rounded-t-3xl rounded-b-[30px] w-full max-w-md h-80 object-cover shadow-lg mt-8"
        />
      </div>

      <!-- Customer Rating Card - Bottom Center -->
      <div class="flex justify-center">
        <div class="bg-gradient-to-br from-[#1F2937] to-[#161F30] p-6 rounded-3xl border border-[#94F9FD]/20 w-full max-w-md backdrop-blur-sm shadow-xl">
          <!-- Header with Icon -->
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <div class="bg-gradient-to-r from-[#2F8EF8] to-[#94F9FD] p-3 rounded-xl shadow-lg">
                <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class="font-bold text-lg text-white" style="font-family: 'Poppins', sans-serif;">Customer Rating</p>
                <p class="text-[#94F9FD]/70 text-xs" style="font-family: 'Poppins', sans-serif;">Verified Reviews</p>
              </div>
            </div>
          </div>
          
          <!-- Rating Display -->
          <div class="flex items-center gap-3 mb-6">
            <div class="flex items-center gap-1">
              <span class="text-[#94F9FD] text-2xl">★</span>
              <span class="text-[#94F9FD] text-2xl">★</span>
              <span class="text-[#94F9FD] text-2xl">★</span>
              <span class="text-[#94F9FD] text-2xl">★</span>
              <span class="text-[#94F9FD] text-2xl">★</span>
            </div>
            <div class="flex flex-col">
              <span class="text-white font-bold text-xl" style="font-family: 'Poppins', sans-serif;">4.9</span>
              <span class="text-[#94F9FD]/70 text-xs" style="font-family: 'Poppins', sans-serif;">40K Reviews</span>
            </div>
          </div>
          
          <!-- Customer Avatars -->
          <div class="flex items-center justify-between">
            <div class="flex -space-x-2">
              <img class="w-12 h-12 rounded-full border-3 border-[#94F9FD]/30 shadow-lg" src="https://i.pravatar.cc/100?u=1" alt="Customer 1" />
              <img class="w-12 h-12 rounded-full border-3 border-[#94F9FD]/30 shadow-lg" src="https://i.pravatar.cc/100?u=2" alt="Customer 2" />
              <img class="w-12 h-12 rounded-full border-3 border-[#94F9FD]/30 shadow-lg" src="https://i.pravatar.cc/100?u=3" alt="Customer 3" />
              <div class="w-12 h-12 rounded-full bg-gradient-to-r from-[#2F8EF8] to-[#94F9FD] flex items-center justify-center text-white border-3 border-[#94F9FD]/30 font-bold shadow-lg" style="font-family: 'Poppins', sans-serif;">
                <span class="text-sm">+37K</span>
              </div>
            </div>
            <div class="text-right">
              <p class="text-[#94F9FD] text-sm font-semibold" style="font-family: 'Poppins', sans-serif;">Trusted by</p>
              <p class="text-white text-xs" style="font-family: 'Poppins', sans-serif;">Happy Clients</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right Column - Content -->
    <div class="lg:pl-10 space-y-8">
      
      <!-- Header Badge -->
      <div class="inline-flex items-center gap-2 bg-gradient-to-r from-[#2F8EF8]/10 to-[#94F9FD]/10 px-4 py-2 rounded-full border border-[#2F8EF8]/20">
        <div class="w-2 h-2 bg-[#2F8EF8] rounded-full animate-pulse"></div>
        <span class="text-sm font-bold uppercase tracking-widest text-[#2F8EF8]" style="font-family: 'Poppins', sans-serif;">Who We Are</span>
      </div>

      <!-- Main Heading -->
      <div class="space-y-4">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight" style="font-family: 'Poppins', sans-serif;">
          <span class="text-white">Creating Spaces</span><br />
          <span class="text-white">That</span> <span class="text-[#94F9FD]">Inspire</span><br />
          <span class="text-white">Everyday Life.</span>
        </h1>
        <div class="w-20 h-1 bg-gradient-to-r from-[#2F8EF8] to-[#94F9FD] rounded-full"></div>
      </div>

      <!-- Description -->
      <div class="space-y-4">
        <p class="text-gray-300 text-lg leading-relaxed" style="font-family: 'Poppins', sans-serif;">
          Our company focuses on designing and building remarkable properties that combine functionality and aesthetics.
        </p>
        <p class="text-gray-400 leading-relaxed" style="font-family: 'Poppins', sans-serif;">
          We believe in integrity, innovation, and creating spaces that truly make a difference in people's lives.
        </p>
      </div>

      <!-- Vision and Mission Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <!-- Our Vision Card -->
        <div class="group bg-gradient-to-br from-[#1F2937] to-[#161F30] p-6 rounded-3xl border border-[#94F9FD]/20 hover:border-[#94F9FD]/40 transition-all duration-300 hover:transform hover:scale-105 hover:shadow-2xl">
          <div class="bg-gradient-to-r from-[#2F8EF8] to-[#94F9FD] w-14 h-14 rounded-2xl flex items-center justify-center mb-6 group-hover:rotate-6 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-white" style="font-family: 'Poppins', sans-serif;">Our Vision</h3>
          <p class="text-gray-400 text-sm leading-relaxed" style="font-family: 'Poppins', sans-serif;">To create exceptional projects that combine quality, design, and trust for all our clients worldwide.</p>
        </div>

        <!-- Our Mission Card -->
        <div class="group bg-gradient-to-br from-[#1F2937] to-[#161F30] p-6 rounded-3xl border border-[#94F9FD]/20 hover:border-[#94F9FD]/40 transition-all duration-300 hover:transform hover:scale-105 hover:shadow-2xl">
          <div class="bg-gradient-to-r from-[#94F9FD] to-[#2F8EF8] w-14 h-14 rounded-2xl flex items-center justify-center mb-6 group-hover:rotate-6 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-white" style="font-family: 'Poppins', sans-serif;">Our Mission</h3>
          <p class="text-gray-400 text-sm leading-relaxed" style="font-family: 'Poppins', sans-serif;">Building high-quality, sustainable projects that exceed client expectations and industry standards.</p>
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6 pt-4">
        <a href="#" class="group bg-gradient-to-r from-[#2F8EF8] to-[#94F9FD] hover:from-[#94F9FD] hover:to-[#2F8EF8] text-white px-8 py-4 rounded-full font-bold flex items-center gap-3 transition-all duration-300 hover:transform hover:scale-105 hover:shadow-xl" style="font-family: 'Poppins', sans-serif;">
          View All Services
          <div class="bg-white/20 backdrop-blur-sm rounded-full w-8 h-8 flex items-center justify-center group-hover:rotate-45 transition-transform duration-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </div>
        </a>
        
        <div class="flex items-center gap-4 group cursor-pointer">
          <div class="bg-gradient-to-r from-[#2F8EF8] to-[#94F9FD] p-4 rounded-2xl group-hover:scale-110 transition-transform duration-300 shadow-lg">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
          </div>
          <div>
            <p class="text-[#94F9FD] text-sm font-semibold" style="font-family: 'Poppins', sans-serif;">Call Us Now</p>
            <p class="font-bold text-white text-lg group-hover:text-[#94F9FD] transition-colors duration-300" style="font-family: 'Poppins', sans-serif;">+(123) 456 78910</p>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Decorative Section Divider - Bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#94F9FD]/20 to-transparent"></div>
</section>

<style>
  .statistics-section {
    font-family: 'Poppins', sans-serif;
  }

  .statistics-section * {
    font-family: 'Poppins', sans-serif !important;
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .statistics-section .grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* Smooth transitions */
  .statistics-section a {
    transition: all 0.3s ease;
  }

  .statistics-section a:hover {
    transform: translateY(-2px);
  }
</style>
