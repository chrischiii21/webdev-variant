---
import { getCollection } from "astro:content";
import Card2 from "../ui/Card2.astro";

// Fetch ourOffering content and sort by order
const offeringItems = await getCollection("ourOffering");
const sortedItems = offeringItems
  .filter(item => item.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<section class="relative text-white py-20 overflow-hidden" style="font-family: 'Poppins', sans-serif;">
  <!-- Subtle Section Background with Glass Effect -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/10 to-transparent"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-[#2F8EF8]/5 via-transparent to-[#94F9FD]/5"></div>

  <!-- Animated Background Orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/3 -left-32 w-80 h-80 bg-[#94F9FD]/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/3 -right-32 w-80 h-80 bg-[#2F8EF8]/10 rounded-full blur-3xl animate-float-delayed"></div>
  </div>

  <!-- Decorative Section Divider - Top -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#94F9FD]/30 to-transparent"></div>
  <div class="absolute top-0 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-transparent via-[#94F9FD]/60 to-transparent blur-sm"></div>

  <div class="max-w-7xl mx-auto relative z-10 px-8">
    
    <!-- Header Section -->
    <div class="text-center mb-16">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-gradient-to-r from-[#94F9FD]/10 to-[#2F8EF8]/10 px-6 py-3 rounded-full border border-[#94F9FD]/20 mb-6">
        <div class="w-2 h-2 bg-[#94F9FD] rounded-full animate-pulse"></div>
        <span class="text-sm font-bold uppercase tracking-widest text-[#94F9FD]">Our Core Offering</span>
      </div>

      <!-- Main Heading -->
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
        <span class="text-white">Digital Blueprints Built for</span><br />
        <span class="bg-gradient-to-r from-[#94F9FD] to-[#2F8EF8] bg-clip-text text-transparent">Business Growth</span>
      </h2>

      <!-- Subtitle -->
      <p class="text-xl text-gray-300 max-w-3xl mx-auto leading-relaxed">
        Specialized website templates for Plumbing and HVAC companies
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedItems.map((item, index) => (
        <Card2 
          icon={item.data.icon}
          title={item.data.title}
          description={item.body || ""}
          index={index}
          variant="offering"
        />
      ))}
    </div>
  </div>

  <!-- Decorative Section Divider - Bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2F8EF8]/30 to-transparent"></div>
  <div class="absolute bottom-0 left-1/4 right-1/4 h-0.5 bg-gradient-to-r from-transparent via-[#2F8EF8]/60 to-transparent blur-sm"></div>
</section>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-20px) scale(1.05);
    }
  }

  @keyframes float-delayed {
    0%, 100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(20px) scale(1.05);
    }
  }

  .animate-float {
    animation: float 8s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float-delayed 8s ease-in-out infinite;
    animation-delay: 2s;
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .grid {
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .grid {
      gap: 1.5rem;
    }
  }
</style>