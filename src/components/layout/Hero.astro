---
// Hero component - Exact replica of reference design with teal colors and original background
import Button from "../ui/Button.astro";

export interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
  backgroundImages?: string[];
}

const {
  title = "Build. Grow. Dominate.",
  subtitle = "Your Growth Partner",
  description = "Over 2,500 contractors and trades professionals have trusted us to elevate their digital presence. Transform your business online and reach more customers than ever before.",
  buttonText = "VIEW OUR WORK",
  buttonLink = "/our-work",
  backgroundImages = [
    "/images/img1.avif",
    "/images/img2.avif",
    "/images/img3.avif",
    "/images/img4.avif",
    "/images/img5.avif",
  ],
} = Astro.props;
---

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Jost:ital@0;1&family=Just+Another+Hand&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">

<section class="relative h-screen flex items-center overflow-hidden" id="hero-section" style="background: linear-gradient(180deg, #2a2a2a 0%, #1a1a1a 30%, #0f0f0f 60%, #000000 100%), radial-gradient(ellipse at center bottom, rgba(147, 51, 234, 0.6) 0%, rgba(126, 34, 206, 0.4) 25%, rgba(88, 28, 135, 0.3) 50%, rgba(55, 48, 163, 0.2) 75%, transparent 100%); background-attachment: fixed; background-size: 100% 100%; background-repeat: no-repeat; min-height: 100vh;">
  <!-- Animated Elements Overlay -->
  <div class="absolute inset-0 z-0">
  </div>

  <!-- Main Content Container -->
  <div class="relative z-10 w-full h-full max-auto">
    
    <!-- Large Background Text - GROW equivalent -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none" id="hero-text">
      <div class="text-center select-none">
        <div class="text-[12rem] md:text-[16rem] lg:text-[20rem] xl:text-[24rem] font-black text-gray-500/20 leading-[0.8] tracking-tighter transition-all duration-300" 
             style="font-family: 'DM Sans', 'Arial Black', 'Helvetica', sans-serif; font-weight: 900; letter-spacing: -0.08em; font-stretch: condensed;">
          GROW
        </div>
      </div>

      <!-- Teal Overlay Text - "Build" and "Dominate" -->
      <div class="absolute inset-0 pointer-events-none" id="hero-overlay-text">
        <!-- "Build" text - left side -->
        <div class="absolute left-1/4 top-1/3 transform -translate-x-1/2 -translate-y-1/2 -rotate-12">
          <h2 class="font-bold italic transition-all duration-75 ease-out text-[#8FA0D8]" 
              style="font-family: 'Just Another Hand', cursive; font-weight: normal; font-size: 14rem; line-height: 0.8;">
            Build
          </h2>
        </div>

        <!-- "Dominate" text - right side -->
        <div class="absolute right-1/4 top-1/3 transform translate-x-1/2 -translate-y-1/2 rotate-12">
          <h2 class="font-bold italic transition-all duration-75 ease-out text-[#8FA0D8]" 
              style="font-family: 'Just Another Hand', cursive; font-weight: normal; font-size: 14rem; line-height: 0.8;">
            Dominate
          </h2>
        </div>
      </div>

      <!-- Left Content Box with Description -->
      <div class="absolute bottom-32 md:bottom-40 w-full">
        <div class="max-w-6xl mx-auto px-8">
          <div class="max-w-md space-y-6">
            <h3 class="text-xl font-bold text-white tracking-wide" 
                style="font-family: 'Arial', 'Helvetica', sans-serif; font-weight: bold; letter-spacing: 0.1em;">
              {subtitle}
            </h3>
            <p class="text-sm text-gray-300 leading-relaxed" 
               style="font-family: 'Arial', 'Helvetica', sans-serif; font-weight: normal;">
              {description}
            </p>
          </div>
        </div>
      </div>

    </div>

    <!-- Button positioned below "Dominate" - moved outside pointer-events-none container -->
    <div class="absolute bottom-48 right-1/4 transform translate-x-1/2 z-20">
      <Button
        variant="primary"
        size="lg"
        href={buttonLink}
        ariaLabel="View our portfolio of completed projects"
      >
        {buttonText}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </Button>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce">
    <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>



<style>
  @keyframes float {
    0%, 100% {
      transform: translate(-50%, -50%) translateY(0px);
    }
    50% {
      transform: translate(-50%, -50%) translateY(-20px);
    }
  }

  @keyframes pulse-slow {
    0%, 100% {
      opacity: 0.2;
      transform: scale(1);
    }
    50% {
      opacity: 0.3;
      transform: scale(1.1);
    }
  }

  @keyframes pulse-slower {
    0%, 100% {
      opacity: 0.15;
      transform: scale(1);
    }
    50% {
      opacity: 0.25;
      transform: scale(1.15);
    }
  }

  .animate-pulse-slow {
    animation: pulse-slow 4s ease-in-out infinite;
  }

  .animate-pulse-slower {
    animation: pulse-slower 6s ease-in-out infinite;
  }

  .animate-float {
    animation: float 8s ease-in-out infinite;
  }

  .bg-gradient-radial {
    background: radial-gradient(
      circle at center,
      transparent 0%,
      rgba(11, 8, 41, 0.5) 50%,
      rgba(11, 8, 41, 1) 100%
    );
  }

  /* Custom responsive font sizes for Build/Dominate text */
  h2[style*="Just Another Hand"] {
    font-size: 14rem !important;
  }

  @media (max-width: 1200px) {
    h2[style*="Just Another Hand"] {
      font-size: 12rem !important;
    }
  }

  @media (max-width: 768px) {
    .text-\[12rem\] {
      font-size: 6rem !important;
    }
    .text-\[8rem\] {
      font-size: 4rem !important;
    }
    h2[style*="Just Another Hand"] {
      font-size: 8rem !important;
    }
    p[style*="Just Another Hand"] {
      font-size: 2rem !important;
    }
  }

  @media (max-width: 640px) {
    .text-\[12rem\] {
      font-size: 4rem !important;
    }
    .text-\[8rem\] {
      font-size: 3rem !important;
    }
    h2[style*="Just Another Hand"] {
      font-size: 6rem !important;
    }
    p[style*="Just Another Hand"] {
      font-size: 1.5rem !important;
    }
  }
</style>
