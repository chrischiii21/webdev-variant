---
// Hero component for Buildr - Construction site style
import Button from "../ui/Button.astro";

export interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
  backgroundImages?: string[];
}

const {
  title = "Build. Grow. Dominate.",
  subtitle = "Your Growth Partner",
  description = "Over 2,500 contractors and trades professionals have trusted us to elevate their digital presence. Transform your business online and reach more customers than ever before.",
  buttonText = "VIEW OUR WORK",
  buttonLink = "#work",
  backgroundImages = [
    "/images/img1.avif",
    "/images/img2.avif",
    "/images/img3.avif",
    "/images/img4.avif",
    "/images/img5.avif",
  ],
} = Astro.props;
---

<section class="relative h-screen flex items-center overflow-hidden">
  <!-- Content -->
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-8">
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center min-h-[80vh]"
    >
      <!-- Left Image -->
      <div
        class="lg:col-span-3 flex justify-center lg:justify-end animate-[fade-in-left_1s_ease-out]"
      >
        <div class="relative">
          <div
            class="w-64 h-80 md:w-72 md:h-96 lg:w-80 lg:h-[28rem] rounded-2xl overflow-hidden shadow-2xl border-2"
            style="border-color: #94F9FD;"
          >
            <img
              src="https://images.unsplash.com/photo-1560472354-b33ff0c44a43?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=626&q=80"
              alt="Professional businessman in construction industry"
              class="w-full h-full object-cover"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"
            >
            </div>
          </div>
        </div>
      </div>

      <!-- Centered Content -->
      <div class="lg:col-span-6 text-center space-y-8">
        <!-- Small Title -->
        <div class="animate-[fade-in_1s_ease-out] mb-6">
          <span class="text-eyebrow" style="color: #94F9FD;">
            Your Growth Partner
          </span>
        </div>

        <!-- Main Heading -->
        <div
          class="space-y-6 animate-[fade-in-up_1s_ease-out] opacity-0 [animation-delay:0.2s] [animation-fill-mode:forwards]"
        >
          <h1 class="heading-primary gradient-text-cyan">
            Build. Grow. Dominate.
          </h1>
        </div>

        <!-- Description -->
        <div
          class="animate-[fade-in-up_1s_ease-out] opacity-0 [animation-delay:0.4s] [animation-fill-mode:forwards]"
        >
          <p class="text-description max-w-2xl mx-auto" style="color: #FFFFFF;">
            Over 2,500 contractors and trades professionals have trusted us to
            elevate their digital presence. Transform your business online and
            reach more customers than ever before.
          </p>
        </div>

        <!-- CTA Button -->
        <div
          class="animate-[fade-in-up_1s_ease-out] opacity-0 [animation-delay:0.6s] [animation-fill-mode:forwards] pt-4"
        >
          <Button
            variant="primary"
            size="lg"
            href="/our-work"
            ariaLabel="View our portfolio of completed projects"
          >
            VIEW OUR WORK
            <svg
              class="w-5 h-5 ml-2"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </Button>
        </div>

        <!-- Trust/Stats Section -->
        <div
          class="animate-[fade-in-up_1s_ease-out] opacity-0 [animation-delay:0.8s] [animation-fill-mode:forwards] pt-8"
        >
          <p class="text-nav mb-4" style="color: #FFFFFF;">
            Trusted by contractors and trades professionals nationwide
          </p>
          <div class="flex items-center justify-center space-x-8 opacity-80">
            <div class="text-nav font-semibold" style="color: #2F8EF8;">
              2,500+
            </div>
            <div class="text-nav font-semibold" style="color: #2F8EF8;">
              Contractors
            </div>
            <div class="text-nav font-semibold" style="color: #2F8EF8;">
              Served
            </div>
            <div class="text-nav font-semibold" style="color: #2F8EF8;">
              Nationwide
            </div>
          </div>
        </div>
      </div>

      <!-- Right Image -->
      <div
        class="lg:col-span-3 flex justify-center lg:justify-start animate-[fade-in-right_1s_ease-out]"
      >
        <div class="relative">
          <div
            class="w-64 h-80 md:w-72 md:h-96 lg:w-80 lg:h-[28rem] rounded-2xl overflow-hidden shadow-2xl border-2"
            style="border-color: #2F8EF8;"
          >
            <img
              src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=676&q=80"
              alt="Professional construction worker with hard hat"
              class="w-full h-full object-cover"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .slideshow-image.active {
    opacity: 1 !important;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in-left {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes fade-in-right {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  /* Responsive typography adjustments */
  @media (max-width: 768px) {
    .hero-lcp div {
      font-size: 4rem !important;
    }
  }

  @media (max-width: 640px) {
    .hero-lcp div {
      font-size: 3rem !important;
    }
  }
</style>
