---
import Button from "../ui/Button.astro";
import StatCard from "../ui/StatCard.astro";
---

<section class="relative py-20 overflow-hidden">
    <!-- Background -->
    <div
        class="absolute inset-0 bg-gradient-to-b from-transparent via-black/5 to-transparent"
    >
    </div>

    <!-- Decorative gradients -->
    <div
        class="absolute top-20 left-0 w-96 h-96 opacity-10 pointer-events-none"
        style="background: radial-gradient(circle, #94F9FD 0%, transparent 70%);"
    >
    </div>
    <div
        class="absolute bottom-20 right-0 w-96 h-96 opacity-8 pointer-events-none"
        style="background: radial-gradient(circle, #2F8EF8 0%, transparent 70%);"
    >
    </div>

    <!-- Decorative Section Divider - Top -->
    <div
        class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#2F8EF8]/20 to-transparent"
    >
    </div>

    <div class="max-w-7xl mx-auto px-8 relative z-10">
        <!-- Section Header -->
        <div class="mb-12">
            <!-- Badge -->
            <div
                class="inline-flex items-center gap-2 bg-gradient-to-r from-[#94F9FD]/10 to-[#2F8EF8]/10 px-4 py-2 rounded-full border border-[#94F9FD]/20 mb-6"
            >
                <div class="w-2 h-2 bg-[#94F9FD] rounded-full animate-pulse">
                </div>
                <span
                    class="text-sm font-bold uppercase tracking-widest text-[#94F9FD]"
                    style="font-family: 'Poppins', sans-serif;"
                >
                    About Us
                </span>
            </div>

            <!-- Main Heading -->
            <h2
                class="text-4xl md:text-5xl lg:text-6xl font-bold text-white max-w-3xl"
                style="font-family: 'Poppins', sans-serif;"
            >
                The Agency Built <span class="text-[#94F9FD]">Different.</span>
            </h2>
        </div>

        <!-- Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 mb-12">
            <!-- Left Column - Manifesto -->
            <div class="flex flex-col justify-between">
                <div class="mb-6">
                    <p
                        class="text-sm font-bold uppercase tracking-widest text-[#2F8EF8] mb-3"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        Our Manifesto
                    </p>
                    <h3
                        class="text-2xl md:text-3xl font-bold text-white mb-4 leading-tight"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        We don't do average marketing for average contractors.
                    </h3>
                    <p
                        class="text-base text-gray-300 leading-relaxed"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        Founded by marketers who grew up around job sites, we
                        build contractor-centric strategies that give trades
                        businesses the unfair advantage they deserve.
                    </p>
                </div>

                <!-- Feature Box -->
                <div
                    class="bg-[#1B222C] border-2 border-[#2F8EF8]/30 rounded-2xl p-6 hover:border-[#94F9FD] transition-all duration-300"
                >
                    <div class="flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-full bg-gradient-to-br from-[#2F8EF8]/20 to-[#94F9FD]/20 flex items-center justify-center flex-shrink-0"
                        >
                            <svg
                                class="w-6 h-6 text-[#94F9FD]"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h4
                                class="text-lg font-bold text-white mb-2"
                                style="font-family: 'Poppins', sans-serif;"
                            >
                                One Goal. More Revenue.
                            </h4>
                            <p
                                class="text-sm text-gray-300 leading-relaxed"
                                style="font-family: 'Poppins', sans-serif;"
                            >
                                Every strategy, every campaign, every decision
                                is designed to put more qualified leads into
                                your pipeline.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column - Stats Grid -->
            <div class="grid grid-cols-2 gap-4">
                <!-- Stat 1 -->
                <div
                    class="stat-card bg-[#1B222C] border-2 border-[#2F8EF8]/30 rounded-2xl p-6 hover:border-[#94F9FD] transition-all duration-300"
                >
                    <div
                        class="w-10 h-10 rounded-full bg-gradient-to-br from-[#2F8EF8]/20 to-[#94F9FD]/20 flex items-center justify-center mb-3"
                    >
                        <svg
                            class="w-5 h-5 text-[#94F9FD]"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </div>
                    <div
                        class="stat-number text-3xl md:text-4xl font-bold mb-2"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        10+
                    </div>
                    <p
                        class="text-gray-400 text-xs"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        Years of Experience
                    </p>
                </div>

                <!-- Stat 2 -->
                <div
                    class="stat-card bg-[#1B222C] border-2 border-[#2F8EF8]/30 rounded-2xl p-6 hover:border-[#94F9FD] transition-all duration-300"
                >
                    <div
                        class="w-10 h-10 rounded-full bg-gradient-to-br from-[#2F8EF8]/20 to-[#94F9FD]/20 flex items-center justify-center mb-3"
                    >
                        <svg
                            class="w-5 h-5 text-[#94F9FD]"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                            ></path>
                        </svg>
                    </div>
                    <div
                        class="stat-number text-xl md:text-2xl font-bold mb-2 leading-tight"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        Built for Trades
                    </div>
                    <p
                        class="text-gray-400 text-xs"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        Industry Specialized
                    </p>
                </div>

                <!-- Stat 3 -->
                <div
                    class="stat-card bg-[#1B222C] border-2 border-[#2F8EF8]/30 rounded-2xl p-6 hover:border-[#94F9FD] transition-all duration-300"
                >
                    <div
                        class="w-10 h-10 rounded-full bg-gradient-to-br from-[#2F8EF8]/20 to-[#94F9FD]/20 flex items-center justify-center mb-3"
                    >
                        <svg
                            class="w-5 h-5 text-[#94F9FD]"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                            ></path>
                        </svg>
                    </div>
                    <div
                        class="stat-number text-3xl md:text-4xl font-bold mb-2"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        500+
                    </div>
                    <p
                        class="text-gray-400 text-xs"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        Contractors Served
                    </p>
                </div>

                <!-- Stat 4 -->
                <div
                    class="stat-card bg-[#1B222C] border-2 border-[#2F8EF8]/30 rounded-2xl p-6 hover:border-[#94F9FD] transition-all duration-300"
                >
                    <div
                        class="w-10 h-10 rounded-full bg-gradient-to-br from-[#2F8EF8]/20 to-[#94F9FD]/20 flex items-center justify-center mb-3"
                    >
                        <svg
                            class="w-5 h-5 text-[#94F9FD]"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                            ></path>
                        </svg>
                    </div>
                    <div
                        class="stat-number text-3xl md:text-4xl font-bold mb-2"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        4.9/5
                    </div>
                    <p
                        class="text-gray-400 text-xs"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        Client Satisfaction
                    </p>
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="text-center">
            <Button
                variant="primary"
                size="lg"
                href="/about"
                ariaLabel="Learn more about us"
            >
                Learn More About Us
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </Button>
        </div>
    </div>

    <!-- Decorative Section Divider - Bottom -->
    <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#94F9FD]/20 to-transparent"
    >
    </div>
</section>

<style>
    .stat-card {
        box-shadow: 0 4px 20px rgba(47, 142, 248, 0.2);
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(148, 249, 253, 0.3);
    }

    .stat-number {
        background: linear-gradient(135deg, #94f9fd 0%, #2f8ef8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
</style>
