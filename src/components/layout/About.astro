---
import Button from "../ui/Button.astro";
import StatCard from "../ui/StatCard.astro";
---

<section class="relative py-20 overflow-hidden bg-[#FAF8F5]">
    <!-- Dynamic Background with Mesh Gradient -->
    <div
        class="absolute inset-0 bg-gradient-to-br from-[#FAF8F5] via-[#F5F3F0] to-[#FAF8F5]"
    >
    </div>
    <div
        class="absolute inset-0 bg-gradient-to-tr from-[#00C2FF]/5 via-transparent to-[#00C2FF]/5"
    >
    </div>

    <!-- Decorative gradients -->
    <div
        class="absolute top-20 left-0 w-96 h-96 opacity-5 pointer-events-none"
        style="background: radial-gradient(circle, #00C2FF 0%, transparent 70%);"
    >
    </div>
    <div
        class="absolute bottom-20 right-0 w-96 h-96 opacity-5 pointer-events-none"
        style="background: radial-gradient(circle, #00C2FF 0%, transparent 70%);"
    >
    </div>

    <!-- Decorative Section Divider - Top -->
    <div
        class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#00C2FF]/20 to-transparent"
    >
    </div>

    <div class="max-w-7xl mx-auto px-8 relative z-10">
        <!-- Section Header -->
        <div class="mb-12">
            <!-- Badge -->
            <div
                class="inline-flex items-center gap-2 bg-[#00C2FF] px-4 py-2 rounded-full border border-[#00C2FF] mb-6"
            >
                <div class="w-2 h-2 bg-white rounded-full">
                </div>
                <span
                    class="text-sm font-bold uppercase tracking-widest text-white"
                    style="font-family: 'Poppins', sans-serif;"
                >
                    About Us
                </span>
            </div>

            <!-- Main Heading -->
            <h2
                class="text-4xl md:text-5xl lg:text-6xl font-bold text-[#0D2B4E] max-w-3xl"
                style="font-family: 'Poppins', sans-serif;"
            >
                The Agency Built <span class="text-[#00C2FF]">Different.</span>
            </h2>
        </div>

        <!-- Content Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 mb-12">
            <!-- Left Column - Manifesto -->
            <div class="flex flex-col justify-between">
                <div class="mb-6">
                    <p
                        class="text-sm font-bold uppercase tracking-widest text-gray-500 mb-3"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        Our Manifesto
                    </p>
                    <h3
                        class="text-2xl md:text-3xl font-bold text-[#0D2B4E] mb-4 leading-tight"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        We don't do average marketing for average contractors.
                    </h3>
                    <p
                        class="text-base text-gray-600 leading-relaxed"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        Founded by marketers who grew up around job sites, we
                        build contractor-centric strategies that give trades
                        businesses the unfair advantage they deserve.
                    </p>
                </div>

                <!-- Feature Box -->
                <div
                    class="bg-white border-2 border-gray-200 rounded-2xl p-6 hover:border-[#00C2FF] transition-all duration-300 shadow-sm"
                >
                    <div class="flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-full bg-[#00C2FF] flex items-center justify-center flex-shrink-0"
                        >
                            <svg
                                class="w-6 h-6 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h4
                                class="text-lg font-bold text-[#0D2B4E] mb-2"
                                style="font-family: 'Poppins', sans-serif;"
                            >
                                One Goal. More Revenue.
                            </h4>
                            <p
                                class="text-sm text-gray-600 leading-relaxed"
                                style="font-family: 'Poppins', sans-serif;"
                            >
                                Every strategy, every campaign, every decision
                                is designed to put more qualified leads into
                                your pipeline.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column - Stats Grid -->
            <div class="grid grid-cols-2 gap-4">
                <StatCard
                    icon="clock"
                    value="10+"
                    label="Years of Experience"
                    variant="dark"
                />
                <StatCard
                    icon="building"
                    value="Built for Trades"
                    label="Industry Specialized"
                    variant="teal"
                />
                <StatCard
                    icon="users"
                    value="500+"
                    label="Contractors Served"
                    variant="dark"
                />
                <StatCard
                    icon="star"
                    value="4.9/5"
                    label="Client Satisfaction"
                    variant="teal"
                />
            </div>
        </div>

        <!-- CTA -->
        <div class="text-center">
            <Button
                variant="primary"
                size="lg"
                href="/about"
                ariaLabel="Learn more about us"
            >
                Learn More About Us
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </Button>
        </div>
    </div>

    <!-- Decorative Section Divider - Bottom -->
    <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#00C2FF]/20 to-transparent"
    >
    </div>
</section>

<style>
    .stat-number {
        background: linear-gradient(135deg, #00C2FF 0%, #0D2B4E 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
</style>