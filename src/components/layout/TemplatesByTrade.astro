---
import TemplateCard from "../ui/TemplateCard.astro";
import Button from "../ui/Button.astro";
import { getCollection } from "astro:content";

// Get all trades and templates
const trades = await getCollection("trades");
const allTemplates = await getCollection("templates");

// Sort trades by order
const sortedTrades = trades.sort((a, b) => a.data.order - b.data.order);

// Group templates by trade and get top 3 for each - SHOW ALL TRADES
const templatesByTrade = sortedTrades.map(trade => {
  const tradeTemplates = allTemplates
    .filter(template => template.data.trade === trade.data.slug)
    .sort((a, b) => a.data.order - b.data.order);
  
  return {
    trade: trade.data,
    templates: tradeTemplates.slice(0, 3), // Top 3 templates
    totalCount: tradeTemplates.length
  };
}); // Show ALL trades, even without templates
---

<!-- Templates by Trade Sections -->
<div class="relative">
    {templatesByTrade.map((item, index) => (
        <section class="relative py-16 overflow-hidden">
            <!-- Background -->
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/5 to-transparent"></div>
            
            {/* Decorative gradients - alternate sides */}
            {index % 2 === 0 ? (
                <div class="absolute top-20 left-0 w-96 h-96 opacity-10 pointer-events-none" style="background: radial-gradient(circle, #8FA0D8 0%, transparent 70%);"></div>
            ) : (
                <div class="absolute top-20 right-0 w-96 h-96 opacity-10 pointer-events-none" style="background: radial-gradient(circle, #8FA0D8 0%, transparent 70%);"></div>
            )}

            {/* Decorative Section Divider - Top */}
            {index === 0 && (
                <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#8FA0D8]/20 to-transparent"></div>
            )}

            <div class="max-w-7xl mx-auto px-8 relative z-10">
                {/* Section Header */}
                <div class="mb-12">
                    {/* Badge */}
                    <div class="inline-flex items-center gap-2 bg-gradient-to-r from-[#8FA0D8]/10 to-[#8FA0D8]/10 px-4 py-2 rounded-full border border-[#8FA0D8]/20 mb-6">
                        <div class="w-2 h-2 bg-[#8FA0D8] rounded-full animate-pulse"></div>
                        <span class="text-sm font-bold uppercase tracking-widest text-[#8FA0D8]" style="font-family: 'Roboto', sans-serif;">
                            {item.trade.name}
                        </span>
                    </div>

                    {/* Section Title and Description */}
                    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
                        <div>
                            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-3" style="font-family: 'Roboto', sans-serif;">
                                {item.trade.name} <span class="text-[#8FA0D8]">Templates</span>
                            </h2>
                            <p class="text-gray-300 text-lg max-w-2xl" style="font-family: 'Roboto', sans-serif;">
                                {item.trade.tagline || `Explore our ${item.trade.name.toLowerCase()} portfolio`}
                            </p>
                        </div>
                        
                        {/* View All Button - Desktop */}
                        {item.totalCount > 3 && (
                            <div class="hidden md:block">
                                <Button
                                    variant="secondary"
                                    size="md"
                                    href={`/trades-we-serve/${item.trade.slug}`}
                                    ariaLabel={`View all ${item.trade.name} templates`}
                                >
                                    View All ({item.totalCount})
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                    </svg>
                                </Button>
                            </div>
                        )}
                    </div>
                </div>

                {/* Templates Grid or Placeholder */}
                {item.templates.length > 0 ? (
                    <>
                        {/* Templates Grid */}
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-8">
                            {item.templates.map((template) => (
                                <TemplateCard
                                    title={template.data.title}
                                    category={template.data.category}
                                    description={template.data.description}
                                    image={template.data.image}
                                    stats={template.data.stats}
                                    href={template.data.liveDemoUrl || template.data.mainSiteUrl || `/trades-we-serve/${item.trade.slug}`}
                                    linkText="View Live Demo"
                                />
                            ))}
                        </div>

                        {/* View All Button - Mobile */}
                        {item.totalCount > 3 && (
                            <div class="md:hidden text-center">
                                <Button
                                    variant="secondary"
                                    size="md"
                                    href={`/trades-we-serve/${item.trade.slug}`}
                                    ariaLabel={`View all ${item.trade.name} templates`}
                                >
                                    View All {item.trade.name} Projects ({item.totalCount})
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                    </svg>
                                </Button>
                            </div>
                        )}
                    </>
                ) : (
                    /* Placeholder for trades without templates */
                    <div class="bg-[#0B0829] border-2 border-[#8FA0D8]/30 rounded-3xl p-12 text-center">
                        <div class="max-w-md mx-auto">
                            <svg class="w-16 h-16 text-[#8FA0D8] mx-auto mb-6 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                            </svg>
                            <h3 class="text-xl font-bold text-white mb-3" style="font-family: 'Roboto', sans-serif;">
                                {item.trade.name} Templates Coming Soon
                            </h3>
                            <p class="text-gray-400 mb-6" style="font-family: 'Roboto', sans-serif;">
                                We're currently working on amazing {item.trade.name.toLowerCase()} templates. Check back soon!
                            </p>
                            <Button
                                variant="secondary"
                                size="sm"
                                href="/contact"
                                ariaLabel={`Contact us about ${item.trade.name} services`}
                            >
                                Get Started
                            </Button>
                        </div>
                    </div>
                )}
            </div>

            {/* Decorative Section Divider - Bottom */}
            <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#8FA0D8]/20 to-transparent"></div>
        </section>
    ))}

    {/* No Templates Message */}
    {templatesByTrade.length === 0 && (
        <section class="py-20">
            <div class="max-w-4xl mx-auto px-8 text-center">
                <div class="bg-[#0B0829] border-2 border-[#8FA0D8]/30 rounded-3xl p-12">
                    <svg class="w-16 h-16 text-[#8FA0D8] mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    <h3 class="text-2xl font-bold text-white mb-4" style="font-family: 'Roboto', sans-serif;">
                        Projects Coming Soon
                    </h3>
                    <p class="text-gray-300 mb-8" style="font-family: 'Roboto', sans-serif;">
                        We're currently building our portfolio. Check back soon to see our amazing work!
                    </p>
                    <Button
                        variant="primary"
                        size="lg"
                        href="/contact"
                        ariaLabel="Contact us to discuss your project"
                    >
                        Start Your Project
                    </Button>
                </div>
            </div>
        </section>
    )}
</div>

<style>
    section {
        font-family: 'Roboto', sans-serif;
    }
</style>
