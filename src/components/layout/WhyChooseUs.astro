---
import { getCollection } from "astro:content";
import Card2 from "../ui/Card2.astro";

// Fetch whyChooseUs content and sort by order
const whyChooseUsItems = await getCollection("whyChooseUs");
const sortedItems = whyChooseUsItems
  .filter((item) => item.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<section
  class="relative text-white py-24 overflow-hidden bg-[#0B0829]"
  style="font-family: 'Roboto', sans-serif;"
>
  <!-- Dynamic Background with Mesh Gradient -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-[#0B0829] via-[#1F1F1F] to-[#0B0829]"
  >
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-tr from-[#8FA0D8]/10 via-transparent to-[#8FA0D8]/10"
  >
  </div>

  <!-- Animated Geometric Shapes -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div
      class="absolute top-20 left-10 w-32 h-32 border border-[#8FA0D8]/20 rounded-full animate-spin-slow"
    >
    </div>
    <div
      class="absolute bottom-20 right-10 w-24 h-24 bg-[#8FA0D8]/10 rounded-lg rotate-45 animate-pulse"
    >
    </div>
    <div
      class="absolute top-1/2 left-1/4 w-16 h-16 border-2 border-[#8FA0D8]/30 rotate-12 animate-bounce-slow"
    >
    </div>
  </div>

  <!-- Decorative Section Dividers -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#8FA0D8]/40 to-transparent"
  >
  </div>
  <div
    class="absolute top-0 left-1/3 right-1/3 h-1 bg-gradient-to-r from-transparent via-[#8FA0D8]/80 to-transparent blur-sm"
  >
  </div>

  <div class="max-w-7xl mx-auto relative z-10 px-8">
    <!-- Header Section with Staggered Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-20">
      <!-- Left Side - Badge and Title -->
      <div>
        <!-- Animated Badge -->
        <div
          class="inline-flex items-center gap-3 bg-gradient-to-r from-[#8FA0D8]/20 to-[#8FA0D8]/20 px-6 py-3 rounded-full border border-[#8FA0D8]/30 mb-8 backdrop-blur-sm"
        >
          <div class="flex gap-1">
            <div class="w-2 h-2 bg-[#8FA0D8] rounded-full animate-pulse"></div>
            <div
              class="w-2 h-2 bg-[#8FA0D8] rounded-full animate-pulse"
              style="animation-delay: 0.2s;"
            >
            </div>
            <div
              class="w-2 h-2 bg-[#8FA0D8] rounded-full animate-pulse"
              style="animation-delay: 0.4s;"
            >
            </div>
          </div>
          <span
            class="text-sm font-bold uppercase tracking-widest text-[#8FA0D8]"
            >Our Values</span
          >
        </div>

        <!-- Main Heading with Split Design -->
        <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-tight">
          <span class="text-white">Why</span>
          <span
            class="block bg-gradient-to-r from-[#8FA0D8] via-[#8FA0D8] to-[#8FA0D8] bg-clip-text text-transparent animate-gradient"
          >
            Choose Us
          </span>
        </h2>
      </div>

      <!-- Right Side - Description -->
      <div class="lg:pl-8">
        <div class="relative">
          <!-- Decorative Quote Mark -->
          <div
            class="absolute -top-4 -left-4 text-6xl text-[#8FA0D8]/20 font-serif"
          >
            "
          </div>

          <p class="text-xl text-gray-300 leading-relaxed relative z-10">
            We're committed to delivering exceptional results through our core
            values and unwavering dedication to your success.
          </p>

          <!-- Accent Line -->
          <div
            class="mt-6 w-24 h-1 bg-gradient-to-r from-[#8FA0D8] to-[#8FA0D8] rounded-full"
          >
          </div>
        </div>
      </div>
    </div>

    <!-- Values Grid with Asymmetric Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        sortedItems.map((item, index) => (
          <Card2
            icon={item.data.icon}
            title={item.data.title}
            description={item.body || ""}
            index={index}
            background="light"
          />
        ))
      }
    </div>
  </div>

  <!-- Bottom Decorative Dividers -->
  <div
    class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#8FA0D8]/40 to-transparent"
  >
  </div>
  <div
    class="absolute bottom-0 left-1/3 right-1/3 h-1 bg-gradient-to-r from-transparent via-[#8FA0D8]/80 to-transparent blur-sm"
  >
  </div>
</section>

<style>
  @keyframes spin-slow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes bounce-slow {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes gradient {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .animate-spin-slow {
    animation: spin-slow 20s linear infinite;
  }

  .animate-bounce-slow {
    animation: bounce-slow 3s ease-in-out infinite;
  }

  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient 3s ease infinite;
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .grid {
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .grid {
      gap: 1rem;
    }
  }
</style>
