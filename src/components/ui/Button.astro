---
interface Props {
    variant?: "primary" | "secondary" | "outline";
    size?: "sm" | "md" | "lg";
    href?: string;
    fullWidth?: boolean;
    theme?: "light" | "dark";
    scrollAdaptive?: boolean;
    ariaLabel?: string;
}

const {
    variant = "primary",
    size = "md",
    href,
    fullWidth = false,
    theme = "dark",
    scrollAdaptive = false,
    ariaLabel,
} = Astro.props;

const baseClasses =
    "inline-flex items-center justify-center font-semibold transition-all duration-300 rounded-lg gap-2";

// Theme-aware variant classes - Orange & Blue Palette
// Optimized for both dark and light backgrounds
const variantClasses = {
    primary: {
        dark: "bg-[#8FA0D8] hover:bg-[#F9DFC6] text-[#FFFFFF] hover:text-[#0B0829] shadow-[0_4px_20px_rgba(143,160,216,0.4)] hover:shadow-[0_6px_30px_rgba(249,223,198,0.8)]",
        light: "bg-[#8FA0D8] hover:bg-[#0B0829] text-[#FFFFFF] hover:text-[#F9DFC6] shadow-[0_4px_20px_rgba(143,160,216,0.4)] hover:shadow-[0_6px_30px_rgba(11,8,41,0.8)]",
    },
    secondary: {
        dark: "bg-[#FF8400] hover:bg-[#F9DFC6] text-[#FFFFFF] hover:text-[#0B0829] border-2 border-[#FF8400] hover:border-[#F9DFC6] shadow-[0_4px_20px_rgba(255,132,0,0.4)] hover:shadow-[0_6px_30px_rgba(249,223,198,0.8)]",
        light: "bg-[#FF8400] hover:bg-[#0B0829] text-[#FFFFFF] hover:text-[#F9DFC6] border-2 border-[#FF8400] hover:border-[#0B0829] shadow-[0_4px_20px_rgba(255,132,0,0.4)] hover:shadow-[0_6px_30px_rgba(11,8,41,0.8)]",
    },
    outline: {
        dark: "border-2 border-[#8FA0D8] text-[#8FA0D8] bg-transparent hover:bg-[#F9DFC6] hover:text-[#0B0829] hover:border-[#F9DFC6] shadow-[0_4px_20px_rgba(143,160,216,0.3)] hover:shadow-[0_6px_30px_rgba(249,223,198,0.8)]",
        light: "border-2 border-[#8FA0D8] text-[#8FA0D8] bg-transparent hover:bg-[#0B0829] hover:text-[#F9DFC6] hover:border-[#0B0829] shadow-[0_4px_20px_rgba(143,160,216,0.3)] hover:shadow-[0_6px_30px_rgba(11,8,41,0.8)]",
    },
};

const sizeClasses = {
    sm: "px-4 py-2 text-sm font-medium",
    md: "px-6 py-3 text-base font-semibold",
    lg: "px-8 py-4 text-lg font-bold",
};

const widthClass = fullWidth ? "w-full" : "";

const classes = `${baseClasses} ${variantClasses[variant][theme]} ${sizeClasses[size]} ${widthClass}`;

const Element = href ? "a" : "button";
---

<Element
    class={classes}
    href={href}
    aria-label={ariaLabel}
    type={href ? undefined : "submit"}
    style="font-family: 'Roboto', sans-serif;"
>
    <slot />
</Element>

<style>
    /* Smooth hover transitions */
    a,
    button {
        transform: translateY(0);
    }

    a:hover,
    button:hover {
        transform: translateY(-2px);
    }
</style>
