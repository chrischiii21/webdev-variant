---
interface Props {
    variant?: "primary" | "secondary" | "outline";
    size?: "sm" | "md" | "lg";
    href?: string;
    fullWidth?: boolean;
    theme?: "light" | "dark";
    scrollAdaptive?: boolean;
    ariaLabel?: string;
}

const {
    variant = "primary",
    size = "md",
    href,
    fullWidth = false,
    theme = "dark",
    scrollAdaptive = false,
    ariaLabel,
} = Astro.props;

const baseClasses =
    "inline-flex items-center justify-center font-semibold transition-all duration-300 rounded-lg gap-2";

const variantClasses = {
    primary:
        "bg-[#2F8EF8] hover:bg-[#94F9FD] text-white hover:text-[#161F30] shadow-[0_4px_20px_rgba(47,142,248,0.4)] hover:shadow-[0_6px_30px_rgba(148,249,253,0.6)]",
    secondary:
        "border-2 border-[#94F9FD] text-[#94F9FD] hover:bg-[#94F9FD] hover:text-[#161F30] shadow-[0_4px_20px_rgba(148,249,253,0.3)] hover:shadow-[0_6px_30px_rgba(148,249,253,0.6)]",
    outline:
        "border-2 border-[#2F8EF8] text-[#2F8EF8] hover:bg-[#2F8EF8] hover:text-white shadow-[0_4px_20px_rgba(47,142,248,0.3)] hover:shadow-[0_6px_30px_rgba(47,142,248,0.6)]",
};

const sizeClasses = {
    sm: "px-4 py-2 text-sm font-medium",
    md: "px-6 py-3 text-base font-semibold",
    lg: "px-8 py-4 text-lg font-bold",
};

const widthClass = fullWidth ? "w-full" : "";

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${widthClass}`;

const Element = href ? "a" : "button";
---

<Element
    class={classes}
    href={href}
    aria-label={ariaLabel}
    type={href ? undefined : "submit"}
    style="font-family: 'Poppins', sans-serif;"
>
    <slot />
</Element>

<style>
    /* Smooth hover transitions */
    a,
    button {
        transform: translateY(0);
    }

    a:hover,
    button:hover {
        transform: translateY(-2px);
    }
</style>
