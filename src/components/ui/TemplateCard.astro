---
import Button from "./Button.astro";

interface Props {
    title: string;
    category: string;
    description: string;
    image?: string;
    stats?: string;
    href: string;
    linkText?: string;
    featured?: boolean;
}

const {
    title,
    category,
    description,
    image,
    stats,
    href,
    linkText = "View Live Demo",
    featured = false,
} = Astro.props;
---

<div class={`template-card ${featured ? "lg:row-span-2" : ""}`}>
    <div class="card-image">
        <img
            src={image ||
                "https://images.unsplash.com/photo-1581094271901-8022df4466f9?auto=format&fit=crop&w=800&q=80"}
            alt={title}
        />
        <div class="image-gradient"></div>

        <!-- Default content overlaid on image -->
        <div class="content-default">
            <h3 class="card-title">{title}</h3>
        </div>
    </div>

    <!-- Hover content -->
    <div class="content-expanded">
        <h3 class="expanded-title">{title}</h3>
        <p class="expanded-description">
            {description}
        </p>
        {
            stats && (
                <div class="flex items-center gap-2 mb-4">
                    <svg
                        class="w-5 h-5 text-[#FF8400]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
                        />
                    </svg>
                    <span
                        class="text-[#FF8400] font-semibold text-sm"
                        style="font-family: 'Roboto', sans-serif;"
                    >
                        {stats}
                    </span>
                </div>
            )
        }
        <Button
            variant="secondary"
            size="sm"
            href={href}
            ariaLabel={`${linkText} - ${title}`}
        >
            {linkText}
            <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
        </Button>
    </div>
</div>

<style>
    .template-card {
        position: relative;
        height: 380px;
        border-radius: 16px;
        overflow: hidden;
        background: #0b0829;
        border: 2px solid #8fa0d8;
        box-shadow: 0 4px 20px rgba(143, 160, 216, 0.3);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Featured card - larger height */
    .template-card.lg\:row-span-2 {
        height: 380px;
    }

    @media (min-width: 1024px) {
        .template-card.lg\:row-span-2 {
            height: 788px; /* 380px * 2 + 28px gap */
        }
    }

    .template-card:hover {
        transform: translateY(-8px);
        box-shadow:
            0 12px 40px rgba(143, 160, 216, 0.5),
            0 0 30px rgba(143, 160, 216, 0.3);
        border-color: #8fa0d8;
    }

    /* Image Section - Full Card */
    .card-image {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .template-card:hover .card-image img {
        transform: scale(1.1);
    }

    .image-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            180deg,
            transparent 0%,
            rgba(11, 8, 41, 0.4) 50%,
            rgba(11, 8, 41, 0.9) 100%
        );
        transition: background 0.4s ease;
    }

    .template-card:hover .image-gradient {
        background: linear-gradient(
            180deg,
            rgba(11, 8, 41, 0.2) 0%,
            rgba(11, 8, 41, 0.5) 50%,
            rgba(11, 8, 41, 0.8) 100%
        );
    }

    /* Default Content - Overlaid at Bottom */
    .content-default {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 28px 32px;
        z-index: 2;
        opacity: 1;
        transition: opacity 0.3s ease;
    }

    .template-card:hover .content-default {
        opacity: 0;
        pointer-events: none;
    }

    .card-title {
        font-family: var(--font-primary);
        font-size: 1.5rem;
        font-weight: 700;
        color: #ffffff;
        line-height: 1.2;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    }

    /* Expanded Content with Glassmorphism */
    .content-expanded {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 28px 32px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        pointer-events: none;
        z-index: 3;
        min-height: 100%;
        /* Glassmorphism effect */
        background: linear-gradient(
            180deg,
            rgba(143, 160, 216, 0.15) 0%,
            rgba(143, 160, 216, 0.35) 40%,
            rgba(143, 160, 216, 0.45) 100%
        );
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    .template-card:hover .content-expanded {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .expanded-title {
        font-family: var(--font-primary);
        font-size: 1.5rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 12px;
        line-height: 1.2;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    }

    .expanded-description {
        font-family: var(--font-primary);
        font-size: 0.95rem;
        color: #ffffff;
        line-height: 1.5;
        margin-bottom: 16px;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    @media (max-width: 768px) {
        .template-card {
            height: 350px;
        }

        .content-default {
            padding: 24px 28px;
        }

        .content-expanded {
            padding: 24px 28px;
        }

        .card-title {
            font-size: 1.25rem;
        }

        .expanded-title {
            font-size: 1.25rem;
            margin-bottom: 10px;
        }

        .expanded-description {
            font-size: 0.875rem;
            margin-bottom: 14px;
        }
    }
</style>
