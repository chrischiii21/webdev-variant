---
interface Props {
    title: string;
    category: string;
    description: string;
    image?: string;
    stats?: string;
    href: string;
    linkText?: string;
    featured?: boolean;
}

const {
    title,
    category,
    description,
    image,
    stats,
    href,
    linkText = "View Templates",
    featured = false,
} = Astro.props;
---

<div
    class={`template-card group relative overflow-hidden rounded-2xl border-2 border-[#2F8EF8]/30 hover:border-[#94F9FD] transition-all duration-500 ${featured ? "lg:row-span-2" : ""}`}
>
    <!-- Image -->
    <div
        class={`relative overflow-hidden ${featured ? "h-[600px]" : "h-[280px]"}`}
    >
        <img
            src={image ||
                "https://images.unsplash.com/photo-1581094271901-8022df4466f9?auto=format&fit=crop&w=800&q=80"}
            alt={title}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <!-- Base Gradient Overlay -->
        <div
            class="absolute inset-0 bg-gradient-to-t from-[#161F30] via-[#161F30]/60 to-transparent"
        >
        </div>

        <!-- Glassmorphism Hover Overlay -->
        <div
            class="template-overlay absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-t from-[#2F8EF8]/45 via-[#2F8EF8]/25 to-[#94F9FD]/15 backdrop-blur-[12px]"
        >
        </div>
    </div>

    <!-- Default Content - Always Visible -->
    <div
        class="content-default absolute bottom-0 left-0 right-0 p-8 z-10 opacity-100 group-hover:opacity-0 transition-opacity duration-300 pointer-events-none"
    >
        <!-- Category Badge -->
        <div
            class="inline-block px-3 py-1 bg-[#2F8EF8]/90 backdrop-blur-sm rounded-full mb-4"
        >
            <span
                class="text-xs font-bold uppercase tracking-wider text-white"
                style="font-family: 'Poppins', sans-serif;"
            >
                {category}
            </span>
        </div>

        <!-- Title -->
        <h3
            class="text-2xl md:text-3xl font-bold text-white"
            style="font-family: 'Poppins', sans-serif;"
        >
            {title}
        </h3>
    </div>

    <!-- Hover Content - Shows on Hover -->
    <div
        class="content-expanded absolute bottom-0 left-0 right-0 p-8 z-10 opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500 pointer-events-none group-hover:pointer-events-auto"
    >
        <!-- Category Badge -->
        <div
            class="inline-block px-3 py-1 bg-[#2F8EF8]/90 backdrop-blur-sm rounded-full mb-4"
        >
            <span
                class="text-xs font-bold uppercase tracking-wider text-white"
                style="font-family: 'Poppins', sans-serif;"
            >
                {category}
            </span>
        </div>

        <!-- Title -->
        <h3
            class="text-2xl md:text-3xl font-bold text-white mb-3 group-hover:text-[#94F9FD] transition-colors"
            style="font-family: 'Poppins', sans-serif;"
        >
            {title}
        </h3>

        <!-- Description -->
        <p
            class="text-white mb-4 leading-relaxed text-shadow-lg"
            style="font-family: 'Poppins', sans-serif;"
        >
            {description}
        </p>

        <!-- Stats -->
        {
            stats && (
                <div class="flex items-center gap-2 mb-4">
                    <svg
                        class="w-5 h-5 text-[#94F9FD]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
                        />
                    </svg>
                    <span
                        class="text-[#94F9FD] font-semibold"
                        style="font-family: 'Poppins', sans-serif;"
                    >
                        {stats}
                    </span>
                </div>
            )
        }

        <!-- Link -->
        <a
            href={href}
            class="inline-flex items-center gap-2 text-white hover:text-[#94F9FD] transition-colors group/link"
            style="font-family: 'Poppins', sans-serif;"
        >
            <span class="font-semibold">{linkText}</span>
            <svg
                class="w-5 h-5 transition-transform group-hover/link:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
        </a>
    </div>
</div>

<style>
    .template-card {
        background: #1b222c;
        box-shadow: 0 4px 20px rgba(47, 142, 248, 0.3);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .template-card:hover {
        transform: translateY(-8px);
        box-shadow:
            0 12px 40px rgba(47, 142, 248, 0.5),
            0 0 30px rgba(148, 249, 253, 0.3);
    }

    .template-overlay {
        -webkit-backdrop-filter: blur(12px);
    }

    .content-default {
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
    }

    .content-expanded {
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);
    }

    .text-shadow-lg {
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
    }
</style>
