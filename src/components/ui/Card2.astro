---
export interface Props {
  icon: string;
  title: string;
  description: string;
  index: number;
  variant?: "default" | "offering";
  background?: "dark" | "light";
}

const { icon, title, description, index, variant = "default", background = "dark" } = Astro.props;
---

<div class="group relative" style={`animation-delay: ${index * 0.1}s;`}>
  
  {variant === "offering" ? (
    <!-- Offering Card Design -->
    <div class="backdrop-blur-sm p-8 rounded-[32px] border relative overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 bg-gradient-to-br from-[#0B0829]/90 to-[#0B0829]/90 border-[#8FA0D8]/30 hover:border-[#8FA0D8]/60">
      
      <!-- Gradient Overlay on Hover -->
      <div class="absolute inset-0 bg-gradient-to-br from-[#8FA0D8]/5 to-[#8FA0D8]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-[32px]"></div>
      
      <!-- Icon Container -->
      <div class="relative mb-6">
        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#8FA0D8]/20 to-[#8FA0D8]/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-500 border border-[#8FA0D8]/30">
          {icon === "template" && (
            <svg class="w-8 h-8 text-[#8FA0D8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          )}
          {icon === "conversion" && (
            <svg class="w-8 h-8 text-[#8FA0D8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          )}
          {icon === "seo" && (
            <svg class="w-8 h-8 text-[#8FA0D8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          )}
        </div>
        
        <!-- Floating Number Badge -->
        <div class="absolute -top-2 -right-2 w-8 h-8 bg-gradient-to-br from-[#FF8400] to-[#FF8400] rounded-full flex items-center justify-center text-white text-sm font-bold shadow-lg">
          {String(index + 1).padStart(2, '0')}
        </div>
      </div>

      <!-- Content -->
      <div class="relative">
        <h3 class="text-xl font-bold mb-4 transition-colors duration-300 text-white group-hover:text-[#FF8400]">
          {title}
        </h3>
        <p class="leading-relaxed text-base transition-colors duration-300 text-gray-300 group-hover:text-gray-200">
          {description}
        </p>
      </div>

      <!-- Decorative Corner Elements -->
      <div class="absolute top-4 right-4 w-12 h-12 border-t-2 border-r-2 border-[#8FA0D8]/20 rounded-tr-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="absolute bottom-4 left-4 w-12 h-12 border-b-2 border-l-2 border-[#8FA0D8]/20 rounded-bl-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    </div>
  ) : (
    <!-- Default WhyChooseUs Card Design -->
    <div class={`relative p-8 rounded-[28px] border backdrop-blur-sm transition-all duration-500 hover:-translate-y-4 ${
      background === "light" 
        ? `bg-gradient-to-br from-white/90 to-[#F9FAFB]/90 border-[#8FA0D8]/20 hover:border-[#8FA0D8]/50 ${
            index % 2 === 0 ? 'mt-0' : 'mt-8'
          }` 
        : `border-[#8FA0D8]/20 hover:border-[#8FA0D8]/50 ${
            index % 2 === 0 
              ? 'bg-gradient-to-br from-[#0B0829]/80 to-[#0B0829]/80 mt-0' 
              : 'bg-gradient-to-br from-[#0B0829]/80 to-[#0B0829]/80 mt-8'
          }`
    }`}>
      
      <!-- Floating Icon Container -->
      <div class="relative mb-6">
        <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[#8FA0D8] to-[#8FA0D8] flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 shadow-lg">
          {icon === "results" && (
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          )}
          {icon === "client" && (
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          )}
          {icon === "support" && (
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          )}
          {icon === "efficient" && (
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          )}
          {icon === "quality" && (
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          )}
          {icon === "innovation" && (
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          )}
          {icon === "experience" && (
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          )}
          {icon === "partnership" && (
            <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />
            </svg>
          )}
        </div>
        
        <!-- Floating Number Badge -->
        <div class="absolute -top-3 -right-3 w-8 h-8 bg-gradient-to-br from-[#FF8400] to-[#FF8400] rounded-full flex items-center justify-center text-white text-sm font-bold shadow-lg border-2 border-white/20">
          {index + 1}
        </div>
      </div>

      <!-- Content -->
      <div class="relative">
        <h3 class={`text-2xl font-bold mb-4 transition-colors duration-300 ${
          background === "light" 
            ? 'text-[#0B0829] group-hover:text-[#FF8400]' 
            : 'text-white group-hover:text-[#FF8400]'
        }`}>
          {title}
        </h3>
        <p class={`leading-relaxed transition-colors duration-300 ${
          background === "light" 
            ? 'text-gray-600 group-hover:text-gray-700' 
            : 'text-gray-300 group-hover:text-gray-200'
        }`}>
          {description}
        </p>
      </div>

      <!-- Hover Glow Effect -->
      <div class="absolute inset-0 rounded-[28px] bg-gradient-to-br from-[#8FA0D8]/10 to-[#8FA0D8]/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
      
      <!-- Corner Accent -->
      <div class="absolute top-4 right-4 w-8 h-8 border-t-2 border-r-2 border-[#8FA0D8]/30 rounded-tr-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    </div>
  )}

  <!-- Connecting Lines (Desktop Only) -->
  {variant === "offering" ? (
    <div class="hidden lg:block absolute top-1/2 -right-4 w-8 h-px bg-gradient-to-r from-[#8FA0D8]/30 to-transparent z-20 last:hidden"></div>
  ) : (
    <div class="hidden lg:block absolute top-1/2 -right-4 w-8 h-px bg-gradient-to-r from-[#8FA0D8]/40 to-transparent z-20 group-hover:from-[#8FA0D8] transition-colors duration-500 last:hidden"></div>
  )}
</div>

<style>
  /* Staggered Animation */
  .group {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .group:nth-child(even) .relative {
      margin-top: 0 !important;
    }
  }
</style>