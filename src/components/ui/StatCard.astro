---
interface Props {
    icon: string;
    value: string;
    label: string;
    variant?: "light" | "dark" | "teal";
}

const { icon, value, label, variant = "light" } = Astro.props;

// Icon mapping
const icons: Record<string, string> = {
    clock: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
    building:
        "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    users: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
    star: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
};

const iconPath = icons[icon] || icons.clock;

// Variant styles
const variantStyles = {
    light: {
        card: "bg-white border-2 border-gray-200 hover:border-[#00C2FF] shadow-sm",
        iconBg: "bg-gradient-to-br from-[#00C2FF]/20 to-[#00C2FF]/40",
        iconColor: "text-[#00C2FF]",
        textColor: "text-gray-600",
        shadowColor: "rgba(0, 194, 255, 0.1)",
        hoverShadowColor: "rgba(0, 194, 255, 0.2)"
    },
    dark: {
        card: "bg-[#0D2B4E] border-2 border-[#0D2B4E] hover:border-[#00C2FF] shadow-sm",
        iconBg: "bg-gradient-to-br from-[#00C2FF]/20 to-[#00C2FF]/40",
        iconColor: "text-[#00C2FF]",
        textColor: "text-gray-300",
        shadowColor: "rgba(41, 37, 36, 0.3)",
        hoverShadowColor: "rgba(0, 194, 255, 0.2)"
    },
    teal: {
        card: "bg-[#00C2FF] border-2 border-[#00C2FF] hover:border-[#FFD100] shadow-sm",
        iconBg: "bg-white/20",
        iconColor: "text-white",
        textColor: "text-white/90",
        shadowColor: "rgba(0, 194, 255, 0.3)",
        hoverShadowColor: "rgba(0, 194, 255, 0.4)"
    }
};

const currentVariant = variantStyles[variant];
---

<div
    class={`stat-card ${currentVariant.card} rounded-2xl p-6 transition-all duration-300`}
    data-variant={variant}
>
    <div
        class={`w-10 h-10 rounded-full ${currentVariant.iconBg} flex items-center justify-center mb-3`}
    >
        <svg
            class={`w-5 h-5 ${currentVariant.iconColor}`}
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d={iconPath}></path>
        </svg>
    </div>
    <div
        class="stat-number text-3xl md:text-4xl font-bold mb-2"
        style="font-family: 'Poppins', sans-serif;"
    >
        {value}
    </div>
    <p
        class={`${currentVariant.textColor} text-xs`}
        style="font-family: 'Poppins', sans-serif;"
    >
        {label}
    </p>
</div>

<style>
    .stat-card {
        transition: all 0.3s ease;
    }

    .stat-card[data-variant="light"] {
        box-shadow: 0 4px 20px rgba(0, 194, 255, 0.1);
    }

    .stat-card[data-variant="light"]:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0, 194, 255, 0.2);
    }

    .stat-card[data-variant="dark"] {
        box-shadow: 0 4px 20px rgba(41, 37, 36, 0.3);
    }

    .stat-card[data-variant="dark"]:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0, 194, 255, 0.2);
    }

    .stat-card[data-variant="teal"] {
        box-shadow: 0 4px 20px rgba(0, 194, 255, 0.3);
    }

    .stat-card[data-variant="teal"]:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0, 194, 255, 0.4);
    }

    .stat-number {
        background: linear-gradient(135deg, #00C2FF 0%, #0D2B4E 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1.2;
    }

    /* Variant-specific number colors */
    .stat-card[data-variant="teal"] .stat-number {
        background: white;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    /* Special handling for multi-line text */
    .stat-number:has(+ p) {
        font-size: clamp(1.25rem, 4vw, 2.5rem);
    }
</style>
