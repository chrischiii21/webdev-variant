---
import Button from "./Button.astro";

interface Props {
    name: string;
    tagline: string;
    hoverTitle?: string;
    hoverDescription?: string;
    image?: string;
    slug: string;
}

const {
    name,
    tagline,
    hoverTitle,
    hoverDescription,
    image = "/images/placeholder.jpg",
    slug,
} = Astro.props;
---

<div class="trade-card">
    <div class="card-image">
        <img src={image} alt={name} />
        <div class="image-gradient"></div>
    </div>

    <div class="card-content">
        <div class="content-default">
            <h3 class="card-title">{name}</h3>
            <p class="card-tagline">{tagline}</p>
        </div>

        <div class="content-expanded">
            <h3 class="expanded-title">{hoverTitle || name}</h3>
            <p class="expanded-description">
                {hoverDescription || tagline}
            </p>
            <Button
                variant="secondary"
                size="sm"
                href={`/trades-we-serve/${slug}`}
                ariaLabel={`Learn more about ${name}`}
            >
                Learn More
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </Button>
        </div>
    </div>
</div>

<style>
    .trade-card {
        position: relative;
        height: 400px;
        border-radius: 16px;
        overflow: hidden;
        background: #1b222c;
        border: 2px solid #2f8ef8;
        box-shadow: 0 4px 20px rgba(47, 142, 248, 0.3);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
    }

    .trade-card:hover {
        transform: translateY(-8px);
        box-shadow:
            0 12px 40px rgba(47, 142, 248, 0.5),
            0 0 30px rgba(148, 249, 253, 0.3);
        border-color: #94f9fd;
    }

    /* Image Section */
    .card-image {
        position: relative;
        width: 100%;
        height: 200px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .trade-card:hover .card-image img {
        transform: scale(1.1);
    }

    .image-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            180deg,
            transparent 0%,
            rgba(27, 34, 44, 0.3) 70%,
            rgba(27, 34, 44, 0.8) 100%
        );
    }

    /* Content Section */
    .card-content {
        position: relative;
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 32px 36px;
    }

    /* Default Content (visible by default) */
    .content-default {
        opacity: 1;
        transition: opacity 0.3s ease;
    }

    .trade-card:hover .content-default {
        opacity: 0;
        pointer-events: none;
    }

    .card-title {
        font-family: var(--font-primary);
        font-size: 1.5rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 12px;
        line-height: 1.3;
    }

    .card-tagline {
        font-family: var(--font-primary);
        font-size: 1rem;
        color: #94f9fd;
        line-height: 1.6;
    }

    /* Expanded Content (visible on hover) */
    .content-expanded {
        position: absolute;
        top: 36px;
        left: 36px;
        right: 36px;
        bottom: 36px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        pointer-events: none;
    }

    .trade-card:hover .content-expanded {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .expanded-title {
        font-family: var(--font-primary);
        font-size: 1.5rem;
        font-weight: 700;
        color: #94f9fd;
        margin-bottom: 16px;
        line-height: 1.3;
    }

    .expanded-description {
        font-family: var(--font-primary);
        font-size: 0.95rem;
        color: #ffffff;
        line-height: 1.7;
        margin-bottom: 28px;
        opacity: 0.95;
    }

    @media (max-width: 768px) {
        .trade-card {
            height: 380px;
        }

        .card-image {
            height: 180px;
        }

        .card-content {
            padding: 28px 32px;
        }

        .content-expanded {
            top: 32px;
            left: 32px;
            right: 32px;
            bottom: 32px;
        }

        .expanded-title {
            font-size: 1.25rem;
            margin-bottom: 14px;
        }

        .expanded-description {
            font-size: 0.875rem;
            margin-bottom: 20px;
        }
    }
</style>
