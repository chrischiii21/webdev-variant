---
import Button from "./Button.astro";

interface Props {
    name: string;
    tagline: string;
    hoverTitle?: string;
    hoverDescription?: string;
    image?: string;
    slug: string;
}

const {
    name,
    tagline,
    hoverTitle,
    hoverDescription,
    image = "/images/placeholder.jpg",
    slug,
} = Astro.props;
---

<div class="trade-card">
    <div class="card-image">
        <img src={image} alt={name} />
        <div class="image-gradient"></div>

        <!-- Default content overlaid on image -->
        <div class="content-default">
            <h3 class="card-title">{name}</h3>
            <p class="card-tagline">{tagline}</p>
        </div>
    </div>

    <!-- Hover content -->
    <div class="content-expanded">
        <h3 class="expanded-title">{hoverTitle || name}</h3>
        <p class="expanded-description">
            {hoverDescription || tagline}
        </p>
        <Button
            variant="secondary"
            size="sm"
            href={`/trades-we-serve/${slug}`}
            ariaLabel={`Learn more about ${name}`}
        >
            Learn More
            <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
        </Button>
    </div>
</div>

<style>
    .trade-card {
        position: relative;
        height: 380px;
        border-radius: 16px;
        overflow: hidden;
        background: #0D2B4E;
        border: 2px solid #00C2FF;
        box-shadow: 0 4px 20px rgba(0, 194, 255, 0.3);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .trade-card:hover {
        transform: translateY(-8px);
        box-shadow:
            0 12px 40px rgba(0, 194, 255, 0.5),
            0 0 30px rgba(0, 194, 255, 0.3);
        border-color: #00C2FF;
    }

    /* Image Section - Full Card */
    .card-image {
        position: relative;
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .trade-card:hover .card-image img {
        transform: scale(1.1);
    }

    .image-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            180deg,
            transparent 0%,
            rgba(10, 15, 30, 0.4) 50%,
            rgba(10, 15, 30, 0.9) 100%
        );
        transition: background 0.4s ease;
    }

    .trade-card:hover .image-gradient {
        background: linear-gradient(
            180deg,
            rgba(10, 15, 30, 0.2) 0%,
            rgba(10, 15, 30, 0.5) 50%,
            rgba(10, 15, 30, 0.8) 100%
        );
    }

    /* Default Content - Overlaid at Bottom */
    .content-default {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 28px 32px;
        z-index: 2;
        opacity: 1;
        transition: opacity 0.3s ease;
    }

    .trade-card:hover .content-default {
        opacity: 0;
        pointer-events: none;
    }

    .card-title {
        font-family: var(--font-primary);
        font-size: 1.75rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 8px;
        line-height: 1.2;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
    }

    .card-tagline {
        font-family: var(--font-primary);
        font-size: 1rem;
        color: #00C2FF;
        line-height: 1.5;
        text-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
    }

    /* Expanded Content with Glassmorphism */
    .content-expanded {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 32px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        pointer-events: none;
        z-index: 3;
        min-height: 100%;
        /* Glassmorphism effect */
        background: linear-gradient(
            180deg,
            rgba(0, 194, 255, 0.15) 0%,
            rgba(0, 194, 255, 0.35) 40%,
            rgba(0, 194, 255, 0.45) 100%
        );
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    .trade-card:hover .content-expanded {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .expanded-title {
        font-family: var(--font-primary);
        font-size: 1.75rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 16px;
        line-height: 1.2;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    }

    .expanded-description {
        font-family: var(--font-primary);
        font-size: 1rem;
        color: #ffffff;
        line-height: 1.6;
        margin-bottom: 24px;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
    }

    @media (max-width: 768px) {
        .trade-card {
            height: 350px;
        }

        .content-default {
            padding: 24px 28px;
        }

        .content-expanded {
            padding: 28px;
        }

        .card-title {
            font-size: 1.5rem;
        }

        .expanded-title {
            font-size: 1.5rem;
            margin-bottom: 14px;
        }

        .expanded-description {
            font-size: 0.9rem;
            margin-bottom: 20px;
        }
    }
</style>
